---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Bảng Giá Gia Công Cắt Decal & Tem Nhãn Mới Nhất 2026";
const pageDescription = "Báo giá cắt decal vi tính, bế tem nhãn lấy liền tại Bình Định. Cam kết độ chính xác cao, hình ảnh thực tế từ các dự án đã bàn giao.";

const priceData = [
  { name: "Cắt Decal màu (Quảng cáo)", price: "Từ 50.000đ/m", unit: "Mét tới", feature: "Decal sữa, decal trong, decal màu" },
  { name: "Cắt Decal mờ (Vách kính)", price: "Từ 60.000đ/m", unit: "Mét tới", feature: "Dán kính văn phòng, shop" },
  { name: "Bế Tem nhãn (Sau in)", price: "Từ 500đ/tem", unit: "Con", feature: "Cắt bế mọi hình dáng phức tạp" },
  { name: "Decal Phản quang", price: "Liên hệ", unit: "Mét", feature: "Decal 3M, decal tổ ong" },
];

const faqs = [
  { q: "Thời gian gia công mất bao lâu?", a: "Với các đơn hàng cắt decal thông thường, chúng tôi có thể trả hàng ngay trong ngày hoặc sau 1-2 giờ tùy khối lượng." },
  { q: "Tôi chưa có file thiết kế thì sao?", a: "Bạn chỉ cần gửi ý tưởng hoặc hình ảnh chụp, đội ngũ kỹ thuật của catdecal.vn sẽ hỗ trợ vẽ lại file vector chuẩn máy cắt." },
  { q: "Xưởng có nhận gửi hàng đi tỉnh không?", a: "Có, chúng tôi đóng gói cuộn lõi cứng chống gãy gập và gửi xe khách hoặc COD toàn quốc từ Bình Định." }
];

const gallery = [
  { url: "https://images.unsplash.com/photo-1611532736597-de2d4265fba3?auto=format&fit=crop&q=80&w=600", title: "Cắt chữ Decal quảng cáo" },
  { url: "https://images.unsplash.com/photo-1589939705384-5185137a7f0f?auto=format&fit=crop&q=80&w=600", title: "Tem nhãn sản phẩm bế tròn" },
  { url: "https://images.unsplash.com/photo-1503387762-592dea58ef23?auto=format&fit=crop&q=80&w=600", title: "Decal mờ vách kính văn phòng" },
  { url: "https://images.unsplash.com/photo-1572375992501-4b0892d50c69?auto=format&fit=crop&q=80&w=600", title: "Decal phản quang xe tải" },
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="bg-[#F5F5F5] py-16">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-bold mb-4 text-black uppercase tracking-tighter">BÁO GIÁ GIA CÔNG 2026</h1>
      <div class="w-20 h-1.5 bg-primary mx-auto mb-6"></div>
      <p class="text-lg text-gray-600">Minh bạch - Chính xác - Lấy liền</p>
    </div>
  </section>

  <section class="py-12 bg-white">
    <div class="max-w-5xl mx-auto px-4">
      <div class="overflow-x-auto rounded-xl border border-divider">
        <table class="w-full text-left">
          <thead>
            <tr class="bg-[#F5F5F5] border-b border-divider">
              <th class="px-6 py-4 font-bold text-black uppercase text-sm">Dịch vụ</th>
              <th class="px-6 py-4 font-bold text-black uppercase text-sm">Đơn giá</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-divider">
            {priceData.map((item) => (
              <tr>
                <td class="px-6 py-5 font-bold text-primary">{item.name}</td>
                <td class="px-6 py-5 text-black font-bold">{item.price} <span class="text-gray-400 font-normal text-xs">/{item.unit}</span></td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <section class="py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-2 text-black uppercase">SẢN PHẨM ĐÃ BÀN GIAO</h2>
      <div class="w-12 h-1 bg-primary mb-8"></div>
      
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {gallery.map((img) => (
          <div class="group relative overflow-hidden rounded-lg shadow-sm">
            <img src={img.url} alt={img.title} class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110" />
            <div class="absolute bottom-0 left-0 right-0 p-4 bg-gradient-to-t from-black/70 to-transparent">
              <p class="text-white text-sm font-medium">{img.title}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 bg-[#F5F5F5]">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold mb-2 text-black uppercase text-center">CÂU HỎI THƯỜNG GẶP</h2>
      <div class="w-12 h-1 bg-primary mx-auto mb-10"></div>
      
      <div class="space-y-6">
        {faqs.map((faq) => (
          <div class="bg-white p-6 rounded-xl shadow-sm border border-divider">
            <h3 class="font-bold text-lg mb-2 text-black flex gap-2">
              <span class="text-primary">Q:</span> {faq.q}
            </h3>
            <p class="text-gray-600 text-sm leading-relaxed">
              <span class="font-bold text-gray-400">A:</span> {faq.a}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
