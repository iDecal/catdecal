---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Ứng dụng dịch vụ cắt decal trong đời sống và quảng cáo - catdecal.vn";
const pageDescription = "Khám phá các ứng dụng thực tế của cắt decal: từ trang trí văn phòng, dán kính, tem nhãn sản phẩm đến các giải pháp quảng cáo chuyên nghiệp.";

const applications = [
  {
    title: "Trang trí vách kính văn phòng",
    desc: "Sử dụng decal mờ cắt line hoặc logo để tạo không gian riêng tư và chuyên nghiệp cho văn phòng làm việc.",
    image: "https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&q=80&w=800",
    features: ["Decal mờ cát", "Cắt logo sắc nét", "Thi công nhanh"]
  },
  {
    title: "Tem nhãn sản phẩm gia công",
    desc: "Cắt bế tem nhãn theo hình dáng yêu cầu cho các shop online, nhãn mỹ phẩm, thực phẩm đóng chai trên toàn quốc.",
    image: "https://images.unsplash.com/photo-1616464916356-3a777b2b59b1?auto=format&fit=crop&q=80&w=800",
    features: ["Bế theo mọi hình dạng", "Chuẩn kích thước file", "Gửi hàng tận nơi"]
  },
  {
    title: "Chữ quảng cáo & Logo Shop",
    desc: "Cắt chữ decal màu dán biển hiệu, dán tường hoặc trang trí cửa kính mặt tiền cho cửa hàng, quán cafe.",
    image: "https://images.unsplash.com/photo-1560179707-f14e90ef3623?auto=format&fit=crop&q=80&w=800",
    features: ["Chống bay màu", "Độ bám dính cao", "Hỗ trợ file vector"]
  },
  {
    title: "Decal phản quang & Kỹ thuật",
    desc: "Cắt decal 3M phản quang cho biển báo, tem xe hoặc các chi tiết kỹ thuật đòi hỏi độ chính xác tuyệt đối.",
    image: "https://images.unsplash.com/photo-1572375992501-4b0892d50c69?auto=format&fit=crop&q=80&w=800",
    features: ["Vật liệu 3M chính hãng", "Cắt chi tiết nhỏ", "Chịu nhiệt tốt"]
  }
];
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="bg-[#F5F5F5] py-20 border-b border-divider">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h1 class="text-3xl md:text-5xl font-bold text-black mb-4 tracking-tighter">Ứng dụng thực tế</h1>
      <div class="w-20 h-1.5 bg-primary mx-auto mb-6"></div>
      <p class="text-gray-600 max-w-2xl mx-auto text-lg leading-relaxed">
        Giải pháp gia công decal đa dạng, đáp ứng mọi nhu cầu từ trang trí nội thất đến quảng cáo thương hiệu cho khách hàng trên toàn quốc.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="space-y-24">
        {applications.map((app, index) => (
          <div class={`flex flex-col lg:flex-row items-center gap-12 ${index % 2 !== 0 ? 'lg:flex-row-reverse' : ''}`}>
            <div class="w-full lg:w-1/2">
              <div class="relative rounded-2xl overflow-hidden border border-divider shadow-sm group">
                <img 
                  src={app.image} 
                  alt={app.title} 
                  class="w-full h-[400px] object-cover transition-transform duration-700 group-hover:scale-105"
                />
              </div>
            </div>

            <div class="w-full lg:w-1/2 space-y-6">
              <h2 class="text-3xl text-black font-bold leading-tight">{app.title}</h2>
              <div class="w-12 h-1 bg-primary"></div>
              <p class="text-gray-500 text-lg leading-relaxed">
                {app.desc}
              </p>
              <ul class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                {app.features.map((feature) => (
                  <li class="flex items-center gap-2 text-sm text-black font-medium">
                    <span class="w-1.5 h-1.5 bg-primary rounded-full"></span>
                    {feature}
                  </li>
                ))}
              </ul>
              <div class="pt-4">
                <a href="/bao-gia" class="inline-block bg-black text-white px-8 py-3 rounded-full font-bold text-sm hover:bg-primary transition-all">
                  Nhận báo giá gia công
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 bg-black text-white">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-bold mb-6">Bạn có ý tưởng thiết kế riêng?</h2>
      <p class="text-gray-400 mb-10 text-lg">Chúng tôi hỗ trợ kiểm tra và xử lý file vector hoàn toàn miễn phí cho đơn hàng gia công toàn quốc.</p>
      <a href="https://zalo.me/sdt-cua-ban" class="bg-primary text-white px-12 py-4 rounded-full font-bold uppercase text-sm hover:brightness-110 transition-all">
        Gửi file qua Zalo ngay
      </a>
    </div>
  </section>
</BaseLayout>
