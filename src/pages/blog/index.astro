---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Lấy dữ liệu an toàn với try-catch để tránh trang trắng khi chưa có bài viết
let allPosts = [];
try {
  const blogEntries = await getCollection('blog');
  allPosts = blogEntries.map(post => ({
    ...post.data,
    slug: post.slug
  }));
} catch (e) {
  console.log("Chưa tìm thấy bộ sưu tập bài viết");
}

// Trích xuất danh sách chuyên mục
const categories = ["Tất cả", ...new Set(allPosts.map(post => post.category))];
---

<BaseLayout title="Blog | CatDecal.vn">
  <section class="pt-24 pb-12">
    <div class="container mx-auto px-4">
      
      {allPosts.length === 0 ? (
        <div class="py-20 text-center">
          <p class="text-slate-400 italic">Hiện tại chưa có bài viết nào được đăng.</p>
          <p class="text-xs text-slate-300 mt-2">Hãy kiểm tra thư mục src/content/blog/ xem đã có file .md chưa nhé!</p>
        </div>
      ) : (
        <div>
           <h1>Blog</h1>
           </div>
      )}

    </div>
  </section>
</BaseLayout>
