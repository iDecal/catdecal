---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Lấy trực tiếp không qua trung gian để test
const posts = await getCollection('blog');
---

<BaseLayout title="Blog">
  <section class="py-20">
    <div class="container mx-auto px-4">
      <h1>BLOG</h1>
      
      <p class="mb-10 text-slate-400">Số lượng bài viết tìm thấy: {posts.length}</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article>
            <a href={`/blog/${post.slug}`}>
              <img src={post.data.image} alt={post.data.title} class="rounded-2xl mb-4" />
              <h3 class="text-xl font-bold">{post.data.title}</h3>
              <p class="text-slate-500">{post.data.excerpt}</p>
            </a>
          </article>
        ))}
      </div>

      {posts.length === 0 && (
        <div class="bg-slate-50 p-10 rounded-3xl text-center">
          <p>Hệ thống chưa tìm thấy file .md nào trong thư mục src/content/blog/</p>
        </div>
      )}
    </div>
  </section>
</BaseLayout>
