---
import BaseLayout from '../../layouts/BaseLayout.astro';

// Giả lập dữ liệu bài viết (Sau này bạn có thể dùng Astro.glob hoặc Content Collections)
const allPosts = [
  {
    title: "Cách chọn Decal dán kính mờ cho văn phòng",
    excerpt: "Hướng dẫn chi tiết cách lựa chọn độ mờ và kiểu cắt logo phù hợp với không gian làm việc.",
    category: "Tư vấn",
    date: "15/04/2026",
    image: "https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=800&auto=format&fit=crop",
    slug: "chon-decal-dan-kinh-mo"
  },
  {
    title: "Xu hướng sử dụng Interior Film năm 2026",
    excerpt: "Tại sao Interior Film đang dần thay thế gỗ công nghiệp trong trang trí nội thất chung cư?",
    category: "Vật liệu",
    date: "10/04/2026",
    image: "https://images.unsplash.com/photo-1616489953149-8f6f691bc73a?q=80&w=800&auto=format&fit=crop",
    slug: "xu-huong-interior-film-2026"
  },
  {
    title: "Quy trình cắt bế tem nhãn sticker số lượng lớn",
    excerpt: "Tìm hiểu hệ thống máy cắt Graphtec giúp tối ưu thời gian và độ chính xác cho đơn hàng tem nhãn.",
    category: "Kỹ thuật",
    date: "05/04/2026",
    image: "https://images.unsplash.com/photo-1589939705384-5185137a7f0f?q=80&w=800&auto=format&fit=crop",
    slug: "quy-trinh-cat-be-tem-nhan"
  }
];

// Trích xuất danh sách chuyên mục duy nhất
const categories = ["Tất cả", ...new Set(allPosts.map(post => post.category))];
---

<BaseLayout title="Blog Chia Sẻ Kiến Thức Decal & Nội Thất | CatDecal.vn">
  
  <section class="pt-24 pb-12 bg-white">
    <div class="container mx-auto px-4">
      <div class="max-w-3xl mb-16">
        <h1 class="mb-6">Kiến thức & <span class="text-slate-400">Dự án</span></h1>
        <p class="text-slate-500">Cập nhật những xu hướng mới nhất về vật liệu trang trí và kỹ thuật gia công decal chuyên nghiệp.</p>
      </div>

      <div class="flex flex-wrap gap-3 mb-12" id="category-filters">
        {categories.map((cat) => (
          <button 
            data-category={cat}
            class="filter-btn px-6 py-2.5 rounded-full text-xs font-bold uppercase tracking-widest border border-slate-100 bg-slate-50 text-slate-400 hover:border-secondary/30 hover:text-secondary transition-all"
          >
            {cat}
          </button>
        ))}
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10" id="blog-grid">
        {allPosts.map((post) => (
          <article class="post-card group flex flex-col" data-category={post.category}>
            <a href={`/blog/${post.slug}`} class="relative block overflow-hidden rounded-2xl mb-6 aspect-[16/10]">
              <img 
                src={post.image} 
                alt={post.title} 
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" 
              />
              <div class="absolute top-4 left-4 bg-white/90 backdrop-blur-md px-3 py-1 rounded-lg text-[10px] font-bold text-slate-800 uppercase tracking-tighter">
                {post.category}
              </div>
            </a>
            
            <div class="flex-1">
              <span class="text-[10px] text-slate-300 font-medium mb-3 block">{post.date}</span>
              <a href={`/blog/${post.slug}`}>
                <h3 class="text-xl mb-3 group-hover:text-secondary transition-colors line-clamp-2">
                  {post.title}
                </h3>
              </a>
              <p class="text-sm text-slate-400 line-clamp-3 mb-6">
                {post.excerpt}
              </p>
              <a href={`/blog/${post.slug}`} class="text-[11px] font-bold uppercase tracking-widest text-slate-900 border-b border-slate-100 pb-1 hover:border-secondary transition-all">
                Đọc bài viết →
              </a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const filterBtns = document.querySelectorAll('.filter-btn');
  const posts = document.querySelectorAll('.post-card');

  // Mặc định chọn nút "Tất cả"
  filterBtns[0]?.classList.add('bg-secondary/10', 'text-secondary', 'border-secondary/20');
  filterBtns[0]?.classList.remove('bg-slate-50', 'text-slate-400');

  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const category = btn.getAttribute('data-category');

      // Update UI nút bấm
      filterBtns.forEach(b => {
        b.classList.remove('bg-secondary/10', 'text-secondary', 'border-secondary/20');
        b.classList.add('bg-slate-50', 'text-slate-400');
      });
      btn.classList.add('bg-secondary/10', 'text-secondary', 'border-secondary/20');
      btn.classList.remove('bg-slate-50', 'text-slate-400');

      // Lọc bài viết
      posts.forEach(post => {
        const postCat = (post as HTMLElement).getAttribute('data-category');
        if (category === "Tất cả" || postCat === category) {
          (post as HTMLElement).style.display = 'flex';
          (post as HTMLElement).classList.add('animate-fade-in');
        } else {
          (post as HTMLElement).style.display = 'none';
        }
      });
    });
  });
</script>

<style>
  .animate-fade-in {
    animation: fadeIn 0.5s ease-in-out forwards;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
