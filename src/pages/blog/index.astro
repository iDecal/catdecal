---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// 1. Lấy tất cả bài viết từ thư mục src/content/blog
const allBlogPosts = await getCollection('blog');

// 2. Chuyển đổi dữ liệu để phù hợp với giao diện (Sắp xếp theo ngày mới nhất)
const allPosts = allBlogPosts.map(post => ({
  ...post.data,
  slug: post.slug // hoặc post.data.slug tùy cấu hình
})).sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());

// 3. Lấy danh sách chuyên mục để làm bộ lọc
const categories = ["Tất cả", ...new Set(allPosts.map(post => post.category))];
---
