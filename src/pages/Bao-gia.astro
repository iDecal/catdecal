---
import BaseLayout from '../layouts/BaseLayout.astro';
import Calculator from '../components/Calculator.astro';

const priceData = [
  {
    category: "Decal Thông Dụng (PVC)",
    items: [
      { name: "Decal Màu (McCal/Avery)", unit: "m2", price: "150.000đ" },
      { name: "Decal Mờ (Dán kính)", unit: "m2", price: "120.000đ" },
      { name: "Decal Trong / Decal Sữa", unit: "m2", price: "180.000đ" },
    ]
  },
  {
    category: "Decal Chuyên Dụng & May Mặc",
    items: [
      { name: "Decal Phản Quang 3M", unit: "m2", price: "450.000đ" },
      { name: "Decal Chuyển Nhiệt PU", unit: "m2", price: "250.000đ" },
      { name: "Decal 7 Màu / Hologram", unit: "m2", price: "350.000đ" },
    ]
  },
  {
    category: "Vật Liệu Kỹ Thuật Cao",
    items: [
      { name: "Interior Film (Giả gỗ/đá)", unit: "m2", price: "650.000đ" },
      { name: "Decal Lưới (Nhìn 1 chiều)", unit: "m2", price: "220.000đ" },
      { name: "Nam Châm Dẻo (Cắt theo bộ)", unit: "Bộ", price: "Liên hệ" },
    ]
  }
];
---

<BaseLayout title="Bảng Giá Gia Công Decal 2026 - CatDecal.vn">
  
  <section class="bg-primary pt-32 pb-20">
    <div class="container mx-auto px-4 text-center">
      <h1 class="text-4xl md:text-5xl font-heading font-black italic text-white uppercase mb-4 tracking-tighter">
        Bảng giá <span class="text-secondary">Gia công 2026</span>
      </h1>
      <p class="text-white/50 max-w-xl mx-auto text-sm italic">
        Giá niêm yết chưa bao gồm thuế VAT và phí thiết kế. Đối với số lượng lớn hoặc đại lý, vui lòng liên hệ trực tiếp để có chiết khấu tốt hơn.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="space-y-16">
        {priceData.map(group => (
          <div class="animate-in fade-in slide-in-from-bottom-4 duration-700">
            <h2 class="text-xs font-black text-slate-400 uppercase tracking-[0.3em] mb-6 flex items-center gap-4">
              {group.category} <span class="h-px bg-slate-100 flex-grow"></span>
            </h2>
            
            <div class="overflow-hidden rounded-3xl border border-slate-100 shadow-sm">
              <table class="w-full text-left border-collapse">
                <thead class="bg-slate-50 border-b border-slate-100">
                  <tr>
                    <th class="p-5 text-[10px] font-black uppercase text-primary tracking-widest">Loại vật liệu</th>
                    <th class="p-5 text-[10px] font-black uppercase text-primary tracking-widest text-center">Đơn vị</th>
                    <th class="p-5 text-[10px] font-black uppercase text-primary tracking-widest text-right">Đơn giá</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-slate-50">
                  {group.items.map(item => (
                    <tr class="hover:bg-slate-50/50 transition-colors group">
                      <td class="p-5 text-sm font-bold text-primary italic uppercase group-hover:text-secondary">{item.name}</td>
                      <td class="p-5 text-xs text-copy-muted text-center font-medium">{item.unit}</td>
                      <td class="p-5 text-base font-black text-primary text-right tracking-tighter">{item.price}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        ))}
      </div>

      <div class="mt-12 p-8 rounded-[2.5rem] bg-secondary/5 border-2 border-dashed border-secondary/20 text-center">
        <p class="text-xs font-bold text-primary uppercase italic">
          * Lưu ý: Đơn hàng tối thiểu (giá sàn) cho mỗi lần gia công là <span class="text-lg text-primary not-italic">30.000đ</span>
        </p>
      </div>
    </div>
  </section>

  <section class="py-24 bg-primary relative overflow-hidden">
    <div class="container mx-auto px-4 relative z-10 text-center">
      <h2 class="text-2xl md:text-3xl font-heading font-black italic text-secondary uppercase mb-8">
        Bạn muốn tính giá theo kích thước riêng?
      </h2>
      <a href="#calc-section" class="inline-block bg-white text-primary px-10 py-5 rounded-2xl font-black uppercase italic hover:scale-105 transition-all shadow-2xl shadow-black/20">
        Mở máy tính báo giá ngay
      </a>
    </div>
  </section>

  <div id="calc-section">
    <Calculator />
  </div>

</BaseLayout>
