---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

// Các mã màu từ logo
const colors = {
  red: "#E31B23",      // Đỏ
  blue: "#00AEEF",     // Xanh Dương
  green: "#8DC63F",    // Xanh Lá
  purple: "#A64499",   // Tím
  black: "#1A1A1A"     // Đen cho chữ
};

const services = [
  {
    title: "Cắt Decal Vi Tính",
    desc: "Cắt chữ, logo dán kính văn phòng, xe cộ sắc nét trên máy Nhật Bản.",
    bgColor: "bg-[#E31B23]/10", // Nền đỏ nhạt
    borderColor: "border-[#E31B23]",
    image: "https://images.unsplash.com/photo-1581092160607-ee22621dd758?q=80&w=600&auto=format&fit=crop",
    label: "Custom logo (viền đỏ)"
  },
  {
    title: "Bế Tem Nhãn",
    desc: "Cắt mọi hình dạng đặc thù cho bao bì sản phẩm, mỹ phẩm, thực phẩm.",
    bgColor: "bg-[#00AEEF]/10", // Nền xanh dương nhạt
    borderColor: "border-[#00AEEF]",
    image: "https://images.unsplash.com/photo-1612817288484-6f916006741a?q=80&w=600&auto=format&fit=crop",
    label: "Product label (viền xanh)"
  },
  {
    title: "Dán Kính & Phim",
    desc: "Thi công decal mờ văn phòng, phim cách nhiệt Solar chống nóng.",
    bgColor: "bg-[#8DC63F]/10", // Nền xanh lá nhạt
    borderColor: "border-[#8DC63F]",
    image: "https://images.unsplash.com/photo-1522204523234-8729aa6e3d5f?q=80&w=600&auto=format&fit=crop",
    label: "Privacy decal (viền xanh)"
  },
  {
    title: "Decal Chuyển Nhiệt",
    desc: "Cắt phim in áo thun, đồng phục chuyên nghiệp, bền màu.",
    bgColor: "bg-[#A64499]/10", // Nền tím nhạt
    borderColor: "border-[#A64499]",
    image: "https://images.unsplash.com/photo-1576566588028-4147f3842f27?q=80&w=600&auto=format&fit=crop",
    label: "Heat transfer (viền tím)"
  }
];
---

<Layout title="Catdecal.vn - Cắt Decal Chuyên Nghiệp | Giao Hàng Toàn Quốc">
  <main class="text-[#1A1A1A] font-sans">
    
    <!-- Hero Section: Nền trắng với Text đen và Banner hình ảnh -->
    <section class="relative h-[450px] flex items-center justify-center overflow-hidden">
      <img src="https://images.unsplash.com/photo-1497366216548-37526070297c?q=80&w=1600&auto=format&fit=crop" 
           class="absolute inset-0 w-full h-full object-cover opacity-20" alt="Background" />
      <div class="relative z-10 text-center px-4">
        <h1 class="text-4xl md:text-6xl font-black mb-4 uppercase tracking-tight">
          CẮT DECAL CHUYÊN NGHIỆP
        </h1>
        <p class="text-lg md:text-xl font-medium mb-10 max-w-2xl mx-auto">
          Sắc nét từng chi tiết - Giao hàng toàn quốc - Giá tốt nhất 2026
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <button class="bg-[#E31B23] text-white px-8 py-3 rounded-md font-bold hover:opacity-90 transition">Xem Bảng Giá 2026</button>
          <button class="bg-[#8DC63F] text-white px-8 py-3 rounded-md font-bold hover:opacity-90 transition">Tư Vấn Zalo</button>
        </div>
      </div>
    </section>

    <!-- Services Section -->
    <section class="py-16 px-4 max-w-7xl mx-auto">
      <h2 class="text-3xl font-bold text-center mb-12 uppercase">Dịch Vụ Nổi Bật</h2>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {services.map(s => (
          <div class={`rounded-xl border-2 ${s.borderColor} ${s.bgColor} overflow-hidden transition-transform hover:scale-[1.02]`}>
            <img src={s.image} alt={s.title} class="w-full h-48 object-cover border-b-2 border-inherit" />
            <div class="p-5">
              <h3 class="font-black text-xl mb-2 uppercase">{s.title}</h3>
              <p class="text-sm font-medium leading-snug mb-4">{s.desc}</p>
              <span class="text-xs font-bold opacity-70 uppercase tracking-widest italic">{s.label}</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- FAQ & Info Section -->
    <section class="py-12 px-4 max-w-7xl mx-auto grid md:grid-cols-3 gap-8 border-t border-gray-200">
      <!-- FAQ -->
      <div class="md:col-span-1 bg-gray-50 p-6 rounded-xl">
        <h3 class="font-bold text-xl mb-6 flex justify-between">FAQ <span>[+]</span></h3>
        <ul class="space-y-4 font-bold text-sm">
          <li class="flex justify-between border-b pb-2">Giao hàng toàn quốc? <span class="text-blue-500">+</span></li>
          <li class="flex justify-between border-b pb-2">Cam kết chất lượng? <span class="text-blue-500">+</span></li>
          <li class="flex justify-between border-b pb-2">Thời gian hoàn thành? <span class="text-blue-500">+</span></li>
        </ul>
      </div>

      <!-- Map/Visual -->
      <div class="md:col-span-1">
        <img src="https://upload.wikimedia.org/wikipedia/commons/e/e4/Vietnam_location_map.svg" 
             class="w-full h-48 object-contain opacity-60" alt="Giao hàng toàn quốc" />
        <p class="text-center font-bold mt-4 uppercase text-xs">Vận chuyển 63 tỉnh thành</p>
      </div>

      <!-- Contact -->
      <div class="md:col-span-1 flex flex-col justify-center items-center bg-[#00AEEF]/5 p-6 rounded-xl border border-[#00AEEF]/20">
        <h3 class="font-bold text-lg mb-4">Liên Hệ & Vận Chuyển</h3>
        <div class="flex gap-4 mb-4">
           <span class="w-10 h-10 bg-[#00AEEF] rounded-full flex items-center justify-center text-white font-bold">Z</span>
           <span class="w-10 h-10 bg-blue-600 rounded-full flex items-center justify-center text-white font-bold">P</span>
           <span class="w-10 h-10 bg-[#8DC63F] rounded-full flex items-center justify-center text-white font-bold">D</span>
        </div>
        <div class="text-3xl font-black text-[#E31B23]">09xx xxx xxx</div>
      </div>
    </section>

  </main>
</astro>
