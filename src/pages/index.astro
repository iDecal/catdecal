---
// 1. Sửa lại đường dẫn Layout cho đúng với file trong thư mục layouts
import Layout from '../../layouts/BaseLayout.astro';

// 2. Import các components - Lưu ý bỏ các dấu '..' dư thừa nếu file index nằm trong src/pages
import Header from '../../components/Header.astro';
import HeaderSlide from '../../components/HeaderSlide.astro';
import Hero from '../../components/Hero.astro';
import AboutHome from '../../components/AboutHome.astro';
import ServicesHome from '../../components/ServicesHome.astro';
import MaterialLayout from '../../components/MaterialLayout.astro';
import Calculator from '../../components/Calculator.astro';
import BlogSection from '../../components/BlogSection.astro';
import FAQSection from '../../components/FAQSection.astro';
import Footer from '../../components/Footer.astro';

// SEO Meta Data
const title = "catdecal.vn - Xưởng Gia Công Cắt Decal Chuyên Nghiệp Quy Nhơn";
const description = "Chuyên cắt gia công decal chữ, logo, bế tem nhãn và cung cấp vật liệu decal phản quang, decal mờ toàn quốc.";
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <Hero />
    <HeaderSlide />
    <AboutHome />
    <ServicesHome />
    <MaterialLayout />
    <Calculator />
    <BlogSection />
    <FAQSection />
  </main>

  <Footer />
</Layout>
