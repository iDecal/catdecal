---
import BaseLayout from '../layouts/BaseLayout.astro';

const faqs = [
  { q: "Cắt decal bao lâu thì lấy được?", a: "Với đơn hàng nhỏ dưới 5 mét, bạn có thể lấy ngay sau 15-30 phút. Đơn hàng số lượng lớn sẽ được giao trong ngày." },
  { q: "Có hỗ trợ thiết kế file vector không?", a: "Có, chúng tôi hỗ trợ kiểm tra và chỉnh sửa file vector miễn phí. Nếu bạn chưa có file, chúng tôi nhận vẽ lại theo mẫu." },
  { q: "Bên mình có dán tận nơi không?", a: "Đội ngũ thợ có mặt tại 22 quận huyện TP.HCM và Bình Định để thi công dán kính, biển hiệu tận nơi." }
];
---

<BaseLayout>
  <section class="bg-primary pt-16 pb-20">
    <div class="container mx-auto px-4">
      <div class="max-w-2xl">
        <h1 class="text-3xl md:text-5xl font-heading font-extrabold text-white leading-tight mb-6">
          Dịch vụ cắt Decal <span class="text-secondary">Chuyên nghiệp</span>
        </h1>
        <p class="text-lg text-white/70 mb-8 leading-relaxed">
          Gia công chính xác, tốc độ bàn giao nhanh và hỗ trợ thi công tận nơi tại TP.HCM & Bình Định.
        </p>
        <div class="flex gap-4">
          <a href="#calculator" class="bg-secondary text-primary px-6 py-3 rounded-custom font-bold text-sm hover:brightness-110 transition-all">
            TÍNH GIÁ NHANH
          </a>
          <a href="https://zalo.me/your-number" class="bg-white/10 text-white px-6 py-3 rounded-custom font-bold text-sm hover:bg-white/20 transition-all">
            ZALO BÁO GIÁ
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="calculator" class="py-20 bg-background">
    <div class="container mx-auto px-4">
      <div class="max-w-4xl mx-auto bg-slate-50 border border-slate-200 p-8 rounded-3xl shadow-sm">
        <div class="text-center mb-10">
          <h2 class="text-2xl font-heading font-bold text-primary italic">CÔNG CỤ TÍNH GIÁ SƠ BỘ</h2>
          <p class="text-sm text-copy-muted mt-2">Nhập kích thước để ước tính chi phí (Giá thay đổi tùy loại decal)</p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 items-end">
          <div class="space-y-2">
            <label class="text-xs font-bold uppercase text-primary/60">Chiều dài (cm)</label>
            <input type="number" id="length" placeholder="Ví dụ: 100" class="w-full p-3 rounded-xl border-slate-200 focus:ring-2 focus:ring-secondary outline-none" />
          </div>
          <div class="space-y-2">
            <label class="text-xs font-bold uppercase text-primary/60">Chiều rộng (cm)</label>
            <input type="number" id="width" placeholder="Ví dụ: 60" class="w-full p-3 rounded-xl border-slate-200 focus:ring-2 focus:ring-secondary outline-none" />
          </div>
          <button id="calcBtn" class="bg-primary text-secondary font-bold p-3 rounded-xl hover:bg-primary/90 transition-all">
            TÍNH KẾT QUẢ
          </button>
        </div>

        <div id="resultBox" class="mt-8 p-6 bg-secondary/10 border border-secondary/20 rounded-2xl hidden">
          <div class="flex justify-between items-center">
            <span class="text-primary font-medium">Ước tính chi phí:</span>
            <span id="priceResult" class="text-2xl font-black text-primary">0đ</span>
          </div>
          <p class="text-[10px] text-primary/50 mt-2">* Lưu ý: Giá trên chỉ mang tính tham khảo cho decal thường, chưa bao gồm công dán và phí thiết kế phức tạp.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-slate-50">
    <div class="container mx-auto px-4 max-w-3xl">
      <h2 class="text-2xl font-heading font-bold text-primary mb-10 text-center uppercase tracking-widest">Hỏi đáp dịch vụ</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-white border border-slate-200 rounded-2xl overflow-hidden">
            <summary class="flex justify-between items-center p-5 cursor-pointer list-none font-bold text-primary group-open:bg-primary group-open:text-secondary transition-all">
              {faq.q}
              <span class="group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="p-5 text-sm leading-relaxed text-copy-muted border-t border-slate-100">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  // Script tính toán đơn giản
  const btn = document.getElementById('calcBtn');
  const resultBox = document.getElementById('resultBox');
  const priceResult = document.getElementById('priceResult');

  btn?.addEventListener('click', () => {
    const l = parseFloat((document.getElementById('length') as HTMLInputElement).value) || 0;
    const w = parseFloat((document.getElementById('width') as HTMLInputElement).value) || 0;
    
    // Giả sử đơn giá: 150.000đ/m2
    const area = (l * w) / 10000;
    const price = Math.max(area * 150000, 30000); // Tối thiểu 30k/đơn

    if (l > 0 && w > 0) {
      priceResult!.innerText = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(price);
      resultBox?.classList.remove('hidden');
    }
  });
</script>
