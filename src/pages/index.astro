---
// 1. Sửa lại đường dẫn Layout cho đúng
import Layout from '../layouts/BaseLayout.astro';

// 2. Import các components - Khớp 100% tên file trong thư mục components
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import HeaderSlide from '../components/HeaderSlide.astro'; // Đã bỏ chữ 's' dư thừa
import AboutHome from '../components/AboutHome.astro';
import ServicesHome from '../components/ServicesHome.astro';
import Material from '../components/Material.astro';
import Calculator from '../components/Calculator.astro';
import BlogSection from '../components/BlogSection.astro';
import FAQSection from '../components/FAQSection.astro';
import Footer from '../components/Footer.astro';

// SEO Meta Data
const title = "catdecal.vn - Xưởng Gia Công Cắt Decal Chuyên Nghiệp Quy Nhơn";
const description = "Chuyên cắt gia công decal chữ, logo, bế tem nhãn và cung cấp vật liệu decal phản quang, decal mờ toàn quốc.";
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <Hero />
    <HeaderSlide />
    <AboutHome />
    <ServicesHome />
    <Material />
    <Calculator />
    <BlogSection />
    <FAQSection />
  </main>

  <Footer />
</Layout>
