---
// Import các component từ thư mục components
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeaderSlide from '../components/HeaderSlide.astro';
import Hero from '../components/Hero.astro';
import AboutHome from '../components/AboutHome.astro';
import ServicesHome from '../components/ServicesHome.astro';
import MaterialLayout from '../components/MaterialLayout.astro';
import Calculator from '../components/Calculator.astro';
import BlogSection from '../components/BlogSection.astro';
import FAQSection from '../components/FAQSection.astro';
import Footer from '../components/Footer.astro';

// SEO Meta Data
const title = "catdecal.vn - Xưởng Gia Công Cắt Decal Chuyên Nghiệp Quy Nhơn";
const description = "Chuyên cắt gia công decal chữ, logo, bế tem nhãn và cung cấp vật liệu decal phản quang, decal mờ toàn quốc.";
---

<Layout title={title} description={description}>
  <Header />

  <main>
    <Hero />

    <HeaderSlide />

    <AboutHome />

    <ServicesHome />

    <MaterialLayout />

    <Calculator />

    <BlogSection />

    <FAQSection />
  </main>

  <Footer />
</Layout>

<style is:global>
  /* Bạn có thể thêm các cấu hình font hoặc màu sắc chủ đạo tại đây nếu cần */
  :root {
    --color-primary: #e11d48; /* Ví dụ màu đỏ iDecal */
  }
  
  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Inter', sans-serif; /* Hoặc font bạn đang dùng */
    background-color: #ffffff;
    color: #333;
  }
</style>
