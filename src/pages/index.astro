---
import BaseLayout from '../layouts/BaseLayout.astro';

// Dữ liệu Blog mẫu (Sau này bạn có thể lấy từ Content Collections của Astro)
const posts = [
  {
    title: "Cách dán decal kính mờ không bị bong bóng khí",
    excerpt: "Hướng dẫn chi tiết từng bước để bạn có thể tự thi công vách kính văn phòng đẹp như thợ...",
    date: "15/04/2026",
    image: "https://images.unsplash.com/photo-1581092160562-40aa08e78837?q=80&w=400&auto=format&fit=crop",
    slug: "huong-dan-dan-decal-kinh"
  },
  {
    title: "Phân biệt Decal phản quang 3M và decal thường",
    excerpt: "Tại sao nên chọn decal phản quang cho biển báo công trình và tem xe hội nhóm...",
    date: "12/04/2026",
    image: "https://images.unsplash.com/photo-1616432043562-3671ea2e5241?q=80&w=400&auto=format&fit=crop",
    slug: "phan-biet-decal-phan-quang"
  },
  {
    title: "Quy chuẩn xuất file AI, PDF để cắt decal sắc nét",
    excerpt: "Những lưu ý quan trọng khi thiết kế file vector để tránh lỗi khi đưa vào máy cắt...",
    date: "10/04/2026",
    image: "https://images.unsplash.com/photo-1561070791-2526d30994b5?q=80&w=400&auto=format&fit=crop",
    slug: "quy-chuan-xuat-file-cat"
  }
];

const faqs = [
  { q: "Tôi ở tỉnh xa làm sao để nhận hàng?", a: "Chúng tôi ship COD toàn quốc qua GHTK, Viettel Post. Hàng được đóng trong ống lõi cứng nên tuyệt đối không gãy gập." },
  { q: "Xưởng có nhận cắt lẻ 1-2 cái không?", a: "Có, chúng tôi nhận gia công mọi số lượng, từ 1 tem nhãn đến hàng nghìn mét decal dự án." },
  { q: "Bên mình có hỗ trợ dán tận nơi không?", a: "Tại TP.HCM và Bình Định, chúng tôi có đội ngũ thợ thi công dán kính, bảng hiệu tận nơi trong ngày." }
];
---

<BaseLayout>
  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-3xl font-heading font-extrabold text-primary italic mb-4 uppercase">Dịch vụ thế mạnh</h2>
      <p class="text-copy-muted max-w-xl mx-auto mb-16">Chúng tôi làm chủ công nghệ cắt CNC hiện đại, đảm bảo độ chính xác tuyệt đối trên mọi vật liệu.</p>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 text-left">
        <div class="group cursor-pointer">
          <div class="overflow-hidden rounded-2xl mb-6 aspect-video bg-slate-100">
             <img src="https://images.unsplash.com/photo-1626708722760-466033488825?q=80&w=600" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" alt="Cắt decal chữ">
          </div>
          <h3 class="text-xl font-bold text-primary group-hover:text-secondary transition-colors mb-2">Cắt Chữ & Logo</h3>
          <p class="text-sm text-copy-muted leading-relaxed">Chuyên vách kính mờ văn phòng, slogan trang trí và biển hiệu cửa hàng.</p>
        </div>
        </div>
    </div>
  </section>

  <section class="py-24 bg-slate-50 border-y border-slate-100">
    <div class="container mx-auto px-4">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
        <div class="max-w-xl">
          <h2 class="text-3xl font-heading font-extrabold text-primary italic uppercase">Blog & Kinh nghiệm</h2>
          <p class="text-copy-muted mt-2 text-sm">Cập nhật xu hướng và hướng dẫn kỹ thuật từ các chuyên gia tại xưởng.</p>
        </div>
        <a href="/blog" class="px-6 py-2 border-2 border-primary text-primary font-bold rounded-full hover:bg-primary hover:text-secondary transition-all text-sm">XEM TẤT CẢ</a>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {posts.map((post) => (
          <article class="bg-white rounded-2xl p-4 shadow-sm hover:shadow-md transition-shadow">
            <img src={post.image} class="w-full h-48 object-cover rounded-xl mb-6" alt={post.title} />
            <span class="text-[10px] font-bold text-secondary bg-primary px-2 py-1 rounded mb-4 inline-block uppercase tracking-wider">{post.date}</span>
            <h3 class="text-lg font-bold text-primary mb-3 leading-tight hover:underline cursor-pointer">{post.title}</h3>
            <p class="text-xs text-copy-muted line-clamp-2 mb-4 leading-relaxed">{post.excerpt}</p>
            <a href={`/blog/${post.slug}`} class="text-xs font-black text-primary border-b-2 border-secondary pb-1">ĐỌC TIẾP</a>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 bg-white">
    <div class="container mx-auto px-4 max-w-4xl">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-heading font-extrabold text-primary italic uppercase">Hỏi đáp khách hàng</h2>
      </div>
      
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group bg-slate-50 border border-slate-100 rounded-2xl overflow-hidden transition-all">
            <summary class="flex justify-between items-center p-6 cursor-pointer list-none font-bold text-primary hover:bg-slate-100 group-open:bg-primary group-open:text-secondary">
              <span>{faq.q}</span>
              <span class="group-open:rotate-180 transition-transform">▼</span>
            </summary>
            <div class="p-6 text-sm text-copy-muted leading-relaxed bg-white border-t border-slate-100">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
