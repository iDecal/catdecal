---
// src/pages/index.astro
import Layout from '../layouts/Layout.astro';

// Cấu hình các dịch vụ theo màu sắc logo
const services = [
  {
    title: "Cắt Decal Vi Tính",
    desc: "Cắt chữ, logo dán kính văn phòng, xe cộ sắc nét trên máy cắt Nhật Bản.",
    color: "border-red-600",
    icon: "✂️"
  },
  {
    title: "Bế Tem Nhãn",
    desc: "Cắt mọi hình dạng đặc thù cho bao bì sản phẩm, mỹ phẩm, thực phẩm.",
    color: "border-blue-500",
    icon: "🏷️"
  },
  {
    title: "Dán Kính & Phim",
    desc: "Thi công decal mờ văn phòng, phim cách nhiệt Solar chống nóng.",
    color: "border-green-500",
    icon: "🏢"
  },
  {
    title: "Decal Chuyển Nhiệt",
    desc: "Cắt phim in áo thun, đồng phục chuyên nghiệp, bền màu.",
    color: "border-purple-600",
    icon: "👕"
  }
];

// Dữ liệu FAQ cho khách hàng
const faqs = [
  {
    q: "Catdecal có giao hàng toàn quốc không?",
    a: "Có, chúng tôi hỗ trợ ship COD hoặc gửi chành xe nhanh chóng đến tất cả các tỉnh thành trên toàn quốc."
  },
  {
    q: "Thời gian hoàn thành đơn hàng là bao lâu?",
    a: "Các đơn hàng cắt lẻ thường hoàn thành ngay trong ngày. Đơn hàng số lượng lớn mất từ 1-3 ngày."
  },
  {
    q: "Tôi cần cung cấp file định dạng gì?",
    a: "Tốt nhất là các file vector (AI, Corel, PDF). Nếu bạn chỉ có hình ảnh, chúng tôi hỗ trợ vẽ lại file miễn phí."
  },
  {
    q: "Giá cắt decal được tính như thế nào?",
    a: "Giá dựa trên loại chất liệu (thường, phản quang, 3M), độ phức tạp của đường cắt và tổng diện tích."
  }
];
---

<Layout title="Catdecal.vn - Cắt Decal Chuyên Nghiệp | Giao Hàng Toàn Quốc">
  <main class="bg-white text-gray-800">
    
    <section class="relative bg-gradient-to-br from-[#00AEEF] to-blue-700 text-white py-24 px-4 text-center">
      <div class="max-w-4xl mx-auto">
        <h1 class="text-4xl md:text-6xl font-bold mb-6 drop-shadow-md">CẮT DECAL CHUYÊN NGHIỆP</h1>
        <p class="text-xl opacity-95 mb-10 max-w-2xl mx-auto">Sắc nét từng chi tiết - Giao hàng toàn quốc - Giải pháp tem nhãn và dán kính tối ưu 2026</p>
        <div class="flex flex-wrap justify-center gap-4">
          <a href="#prices" class="bg-[#E31B23] hover:bg-red-700 text-white px-10 py-4 rounded-full font-bold shadow-lg transition-all transform hover:scale-105">Xem Bảng Giá</a>
          <a href="https://zalo.me/your_number" class="bg-[#8DC63F] hover:bg-green-600 text-white px-10 py-4 rounded-full font-bold shadow-lg transition-all transform hover:scale-105">Tư Vấn Zalo</a>
        </div>
      </div>
    </section>

    <section class="py-20 px-4 max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl font-bold mb-4">Dịch Vụ Trọng Tâm</h2>
        <div class="w-24 h-1 bg-[#E31B23] mx-auto"></div>
      </div>
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-8">
        {services.map(s => (
          <div class={`p-8 border-t-4 ${s.color} bg-gray-50 rounded-b-xl shadow-sm hover:shadow-xl transition-all duration-300 group`}>
            <div class="text-4xl mb-6 group-hover:scale-110 transition-transform inline-block">{s.icon}</div>
            <h3 class="font-bold text-xl mb-3 text-gray-900">{s.title}</h3>
            <p class="text-gray-600 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </section>

    <section class="py-20 px-4 bg-gray-100">
      <div class="max-w-3xl mx-auto">
        <h2 class="text-3xl font-bold text-center mb-12">Câu Hỏi Thường Gặp</h2>
        <div class="space-y-4">
          {faqs.map(faq => (
            <details class="group bg-white p-6 rounded-xl shadow-sm open:shadow-md transition-all">
              <summary class="font-bold text-lg cursor-pointer list-none flex justify-between items-center text-[#00AEEF]">
                {faq.q}
                <span class="text-2xl group-open:rotate-180 transition-transform">+</span>
              </summary>
              <div class="mt-4 text-gray-700 border-t pt-4 leading-relaxed">
                {faq.a}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>

    <section class="py-24 px-4 text-center">
      <div class="max-w-2xl mx-auto bg-white p-10 rounded-2xl border-2 border-dashed border-gray-200">
        <h2 class="text-3xl font-bold mb-4 text-[#A64499]">Bạn cần báo giá nhanh sau 5 phút?</h2>
        <p class="mb-8 text-gray-600 text-lg italic">"Giao hàng toàn quốc - Khảo sát tận nơi tại TP.HCM & Bình Dương"</p>
        <div class="text-4xl font-black text-[#E31B23] mb-6 tracking-wider">09xx xxx xxx</div>
        <p class="text-sm text-gray-400 uppercase tracking-widest font-semibold">Phục vụ tận tâm - Uy tín dẫn đầu</p>
      </div>
    </section>

  </main>
</Layout>

<style>
  /* Tối ưu font và hiệu ứng cuộn */
  html {
    scroll-behavior: smooth;
  }
  body {
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
  }
</style>
