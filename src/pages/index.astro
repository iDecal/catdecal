---
import BaseLayout from '../layouts/BaseLayout.astro';

const topServices = [
  { title: "Cắt Chữ & Logo", image: "https://images.unsplash.com/photo-1626708722760-466033488825?q=80&w=500&auto=format&fit=crop", link: "/dich-vu/cat-decal-chu-logo" },
  { title: "Tem Nhãn Sticker", image: "https://images.unsplash.com/photo-1589987607627-616cac5c2c5a?q=80&w=500&auto=format&fit=crop", link: "/tem-nhan" },
  { title: "Decal Phản Quang", image: "https://images.unsplash.com/photo-1616432043562-3671ea2e5241?q=80&w=500&auto=format&fit=crop", link: "/phan-quang" },
  { title: "Cắt Gia Công B2B", image: "https://images.unsplash.com/photo-1581092160562-40aa08e78837?q=80&w=500&auto=format&fit=crop", link: "/gia-cong" }
];

const materialRates = [
  { id: 'mo', name: 'Decal Mờ (Văn phòng)', price: 120000 },
  { id: 'mau', name: 'Decal Màu (Thường)', price: 150000 },
  { id: 'phanquang', name: 'Decal Phản Quang 3M', price: 450000 },
  { id: 'trong', name: 'Decal Trong/Sữa', price: 180000 }
];
---

<BaseLayout title="Cắt Decal Theo Yêu Cầu - Tính Giá & Gửi File Online">
  
  <section class="relative h-[80vh] flex items-center overflow-hidden bg-primary">
    <div class="absolute inset-0 z-0">
      <img 
        src="https://images.unsplash.com/photo-1611532736597-de2d4265fba3?q=80&w=2000&auto=format&fit=crop" 
        class="w-full h-full object-cover opacity-40 scale-105" 
        alt="Xưởng cắt decal"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/80 to-transparent"></div>
    </div>
    
    <div class="container mx-auto px-4 relative z-10">
      <div class="max-w-2xl">
        <h1 class="text-3xl md:text-5xl font-heading font-extrabold text-white leading-tight mb-6">
          Giải pháp cắt Decal <br /> 
          <span class="text-secondary">Chính xác & Giao hàng nhanh</span>
        </h1>
        <p class="text-lg text-white/80 mb-10 leading-relaxed italic">
          Chuyên dán kính văn phòng, tem nhãn Sticker. Hỗ trợ file AI, PDF, Corel.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#calculator" class="bg-secondary text-primary px-8 py-4 rounded-custom font-bold text-sm hover:scale-105 transition-all">
            TÍNH GIÁ & GỬI FILE
          </a>
          <a href="https://zalo.me/your-number" class="bg-white/10 backdrop-blur-md text-white border border-white/20 px-8 py-4 rounded-custom font-bold text-sm hover:bg-white/20 transition-all">
            TƯ VẤN ZALO
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="calculator" class="py-24 bg-slate-50">
    <div class="container mx-auto px-4">
      <div class="max-w-5xl mx-auto">
        <div class="grid grid-cols-1 lg:grid-cols-5 gap-8 bg-white rounded-[2rem] shadow-xl overflow-hidden border border-slate-100">
          
          <div class="lg:col-span-3 p-8 md:p-12 space-y-8">
            <h2 class="text-2xl font-heading font-bold text-primary flex items-center gap-3 italic">
              <span class="w-8 h-8 bg-secondary rounded-full flex items-center justify-center text-sm not-italic">1</span>
              Thông số đơn hàng
            </h2>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Loại vật liệu</label>
                <select id="material" class="w-full p-4 rounded-xl bg-slate-50 border-none focus:ring-2 focus:ring-secondary outline-none">
                  {materialRates.map(m => <option value={m.price}>{m.name}</option>)}
                </select>
              </div>
              <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Số lượng</label>
                <input type="number" id="quantity" value="1" min="1" class="w-full p-4 rounded-xl bg-slate-50 border-none focus:ring-2 focus:ring-secondary outline-none" />
              </div>
              <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Dài (cm)</label>
                <input type="number" id="length" placeholder="0" class="w-full p-4 rounded-xl bg-slate-50 border-none focus:ring-2 focus:ring-secondary outline-none" />
              </div>
              <div class="space-y-2">
                <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Rộng (cm)</label>
                <input type="number" id="width" placeholder="0" class="w-full p-4 rounded-xl bg-slate-50 border-none focus:ring-2 focus:ring-secondary outline-none" />
              </div>
            </div>

            <button id="calcBtn" class="w-full bg-primary text-secondary font-black p-5 rounded-xl hover:brightness-125 transition-all shadow-lg shadow-primary/20">
              TÍNH GIÁ NGAY
            </button>
          </div>

          <div class="lg:col-span-2 bg-primary p-8 md:p-12 text-white flex flex-col">
            <h2 class="text-xl font-heading font-bold text-secondary mb-6 italic">Kết quả & Gửi file</h2>
            
            <div id="resultBox" class="mb-8 hidden animate-in fade-in duration-500">
              <span class="text-white/50 text-xs uppercase block mb-1">Tổng cộng dự kiến:</span>
              <div id="priceResult" class="text-4xl font-black text-secondary tracking-tighter">0đ</div>
            </div>

            <div class="mt-auto space-y-6">
              <div class="p-6 border-2 border-dashed border-white/20 rounded-2xl hover:border-secondary transition-colors group relative">
                <input type="file" id="fileUpload" class="absolute inset-0 opacity-0 cursor-pointer" accept=".ai,.pdf,.eps,.cdr" />
                <div class="text-center">
                  <svg class="w-8 h-8 mx-auto mb-3 text-secondary group-hover:scale-110 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
                  <p class="text-xs font-bold text-white uppercase mb-1">Tải file thiết kế</p>
                  <p class="text-[10px] text-white/40">Hỗ trợ: AI, PDF, CDR, EPS</p>
                </div>
              </div>
              <p id="fileName" class="text-xs text-secondary italic hidden"></p>
              
              <button class="w-full bg-white text-primary font-bold p-4 rounded-xl hover:bg-secondary transition-colors flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 14h2v2h-2v-2zm0-10h2v8h-2V6z"/></svg>
                GỬI ĐƠN HÀNG ZALO
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const btn = document.getElementById('calcBtn');
  const resultBox = document.getElementById('resultBox');
  const priceResult = document.getElementById('priceResult');
  const fileInput = document.getElementById('fileUpload') as HTMLInputElement;
  const fileNameDisplay = document.getElementById('fileName');

  // Xử lý hiện tên file khi chọn
  fileInput?.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file && fileNameDisplay) {
      fileNameDisplay.innerText = `📄 Đã chọn: ${file.name}`;
      fileNameDisplay.classList.remove('hidden');
    }
  });

  // Logic tính giá
  btn?.addEventListener('click', () => {
    const rate = parseFloat((document.getElementById('material') as HTMLSelectElement).value);
    const qty = parseFloat((document.getElementById('quantity') as HTMLInputElement).value) || 1;
    const l = parseFloat((document.getElementById('length') as HTMLInputElement).value) || 0;
    const w = parseFloat((document.getElementById('width') as HTMLInputElement).value) || 0;
    
    const area = (l * w) / 10000;
    let total = area * rate * qty;
    
    // Áp dụng giá sàn
    if (total < 30000 && l > 0) total = 30000;

    if (l > 0 && w > 0) {
      priceResult!.innerText = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(total);
      resultBox?.classList.remove('hidden');
    }
  });
</script>
