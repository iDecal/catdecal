---
import Layout from '../layouts/BaseLayout.astro';
import Calculator from '../components/Calculator.astro';

// SEO Meta
const title = "Dịch vụ cắt Decal & Gia công chuyên nghiệp - CatDecal.vn";
const description = "Xưởng gia công decal tại Bình Định: Cắt decal màu, mờ dán kính, phản quang 3M, tem nhãn và decal chuyển nhiệt ép áo. Nhận hàng ngay trong ngày, giao hàng toàn quốc.";
---

<Layout title={title} description={description}>
  <section class="bg-secondary py-16 px-4 text-center">
    <div class="max-w-4xl mx-auto">
      <h1 class="text-4xl md:text-5xl font-heading font-bold text-white mb-6">
        Giải Pháp <span class="text-primary">Cắt Decal</span> Gia Công Chuyên Nghiệp
      </h1>
      <p class="text-gray-400 text-lg mb-8">
        Từ cắt chữ quảng cáo đến tem nhãn kỹ thuật cao. Chúng tôi giúp bạn hoàn thiện sản phẩm với độ chính xác tuyệt đối và thời gian nhanh nhất.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a href="#bao-gia" class="bg-primary hover:bg-primary-dark text-white px-8 py-3 rounded-full font-bold transition-all">Tính giá ngay</a>
        <a href="https://zalo.me/SĐT_CỦA_BẠN" class="bg-white/10 hover:bg-white/20 text-white px-8 py-3 rounded-full font-bold transition-all border border-white/20">Tư vấn qua Zalo</a>
      </div>
    </div>
  </section>

  <section class="py-20 px-4 max-w-7xl mx-auto">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-bold text-secondary mb-4">Các dịch vụ trọng tâm</h2>
      <p class="text-copy-muted">Phục vụ nhu cầu quảng cáo, trang trí nội thất và may mặc</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <div class="bg-surface p-8 rounded-2xl border border-divider hover:shadow-xl transition-all group">
        <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center text-primary mb-6 group-hover:bg-primary group-hover:text-white transition-all">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path></svg>
        </div>
        <h3 class="text-xl font-bold mb-3 text-secondary">Cắt Decal Màu & Mờ</h3>
        <p class="text-sm text-copy-muted leading-relaxed">Chuyên cắt chữ quảng cáo, logo công ty và decal mờ dán kính văn phòng. Đường cắt sắc nét, dễ lột nền.</p>
      </div>

      <div class="bg-surface p-8 rounded-2xl border border-divider hover:shadow-xl transition-all group">
        <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center text-primary mb-6 group-hover:bg-primary group-hover:text-white transition-all">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path></svg>
        </div>
        <h3 class="text-xl font-bold mb-3 text-secondary">Cắt Bế Tem Nhãn</h3>
        <p class="text-sm text-copy-muted leading-relaxed">Gia công cắt bế chính xác theo đường viền cho tem xe, tem nhãn sản phẩm sau khi in. Hỗ trợ file khổ lớn.</p>
      </div>

      <div class="bg-surface p-8 rounded-2xl border border-divider hover:shadow-xl transition-all group">
        <div class="w-14 h-14 bg-primary/10 rounded-xl flex items-center justify-center text-primary mb-6 group-hover:bg-primary group-hover:text-white transition-all">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
        </div>
        <h3 class="text-xl font-bold mb-3 text-secondary">Decal Phản Quang & Nhiệt</h3>
        <p class="text-sm text-copy-muted leading-relaxed">Cung cấp và gia công decal phản quang 3M cho biển báo và decal chuyển nhiệt chất lượng cao cho ngành may mặc.</p>
      </div>
    </div>
  </section>

  <section id="bao-gia" class="py-20 bg-background-alt px-4">
    <div class="max-w-7xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-secondary">Báo giá hỏa tốc</h2>
        <p class="text-copy-muted mt-2">Nhập kích thước để nhận báo giá và đặt lịch nhận hàng ngay</p>
      </div>
      <Calculator />
    </div>
  </section>

  <section class="py-20 px-4 max-w-5xl mx-auto">
    <div class="bg-secondary rounded-3xl p-8 md:p-12 text-white relative overflow-hidden">
      <div class="relative z-10">
        <h2 class="text-3xl font-bold mb-8 italic">"Gói hàng bằng tâm - Giao hàng bằng tốc"</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="flex gap-4">
            <div class="text-primary text-2xl font-bold">01.</div>
            <div>
              <h4 class="font-bold mb-2">Đúng tiến độ</h4>
              <p class="text-gray-400 text-sm">Hệ thống quản lý đơn hàng thông minh giúp chúng tôi cam kết thời gian giao hàng chính xác.</p>
            </div>
          </div>
          <div class="flex gap-4">
            <div class="text-primary text-2xl font-bold">02.</div>
            <div>
              <h4 class="font-bold mb-2">Giá xưởng tại gốc</h4>
              <p class="text-gray-400 text-sm">Không qua trung gian, tối ưu chi phí cho anh em thợ quảng cáo và đại lý.</p>
            </div>
          </div>
        </div>
      </div>
      <div class="absolute top-0 right-0 w-64 h-64 bg-primary/5 rounded-full -mr-32 -mt-32"></div>
    </div>
  </section>
</Layout>
