---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title = "CATDECAL.VN - Gia công Decal & Interior Film Chuyên Nghiệp", 
  description = "Dịch vụ cắt decal vi tính, bế tem nhãn, trang trí nội thất và film dán nội thất lấy liền tại Bình Định và TP.HCM.",
  image = "/og-image.jpg" 
} = Astro.props;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:ital,wght@0,400;0,700;0,800;1,400;1,700;1,800&family=Inter:wght@400;500;700&display=swap" rel="stylesheet" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />
  </head>
  <body class="bg-white text-[#2f2f2f] font-body antialiased selection:bg-secondary/30">
    
    <Header />

    <main> 
      <slot /> 
    </main>

    <Footer />

    <style is:global>
      /* 1. QUẢN LÝ KÍCH THƯỚC & MÀU SẮC FONT CHỮ TOÀN SITE */
      :root {
        --font-main: 'Be Vietnam Pro', sans-serif;
        --color-text-dark: #2f2f2f; /* Màu đen theo style Cricut */
      }

      body {
        font-family: var(--font-main);
        color: var(--color-text-dark);
      }

      h1 {
        /* text-black giúp tiêu đề có màu đen */
        @apply text-3xl md:text-5xl lg:text-6xl font-bold tracking-tighter uppercase leading-[1.1] text-black;
      }

      h2 {
        @apply text-2xl md:text-4xl font-bold tracking-tight leading-snug text-black;
      }

      h3 {
        @apply text-xl md:text-2xl font-bold tracking-tight text-black;
      }

      p {
        @apply leading-relaxed text-[#4a4a4a]; /* Màu xám đậm cho nội dung text để dễ đọc */
      }

      /* 2. TỐI ƯU HIỆU ỨNG */
      html {
        scroll-behavior: smooth;
      }

      /* Custom scrollbar */
      ::-webkit-scrollbar {
        width: 6px;
      }
      ::-webkit-scrollbar-track {
        @apply bg-slate-50;
      }
      ::-webkit-scrollbar-thumb {
        @apply bg-slate-300 rounded-full hover:bg-primary transition-colors;
      }

      .font-heading {
        font-family: var(--font-main);
      }
    </style>
  </body>
</html>
