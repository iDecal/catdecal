---
import Header from '../components/Header.astro';
import { brand } from '../config/brand'; // File cấu hình brand đã tạo trước đó

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const { 
  title = "CẮT DECAL PRO - Chính xác, Tốc độ, Giá xưởng", 
  description = "Dịch vụ cắt decal vi tính lấy liền, dán kính văn phòng, tem nhãn sticker chuyên nghiệp tại TP.HCM và Bình Định.",
  image = "/og-image.jpg" 
} = Astro.props;
---

<!doctype html>
<html lang="vi">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@400;500;700;800&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(image, Astro.url)} />

    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={Astro.url} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={new URL(image, Astro.url)} />
  </head>
  <body class="bg-background text-copy font-body antialiased">
    
    <Header />

    <main>
      <slot /> </main>

    <footer class="bg-primary text-white pt-16 pb-8">
      <div class="container mx-auto px-4">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-12">
          <div class="col-span-1 md:col-span-2">
            <h2 class="text-2xl font-heading font-bold mb-4">
              CATDECAL<span class="text-secondary">.VN</span>
            </h2>
            <p class="text-white/70 max-w-sm mb-6">
              Đơn vị chuyên nghiệp trong lĩnh vực cắt decal vi tính, dán kính văn phòng và gia công tem nhãn theo yêu cầu.
            </p>
            <div class="flex gap-4">
              </div>
          </div>
          
          <div>
            <h3 class="font-heading font-bold text-lg mb-4 text-secondary">Dịch vụ</h3>
            <ul class="space-y-2 text-white/70 text-sm">
              <li><a href="/dich-vu/cat-decal-chu-logo" class="hover:text-secondary">Cắt decal Chữ/Logo</a></li>
              <li><a href="/dich-vu/tem-nhan-sticker" class="hover:text-secondary">Tem nhãn & Sticker</a></li>
              <li><a href="/dich-vu/decal-phan-quang" class="hover:text-secondary">Decal Phản quang</a></li>
              <li><a href="/dich-vu/dan-decal-tan-noi" class="hover:text-secondary">Dán decal tận nơi</a></li>
            </ul>
          </div>

          <div>
            <h3 class="font-heading font-bold text-lg mb-4 text-secondary">Liên hệ</h3>
            <p class="text-white/70 text-sm mb-2">📍 TP. Hồ Chí Minh & Bình Định</p>
            <p class="text-white/70 text-sm mb-2">📞 Hotline: 090x xxx xxx</p>
            <p class="text-white/70 text-sm">✉️ Email: contact@catdecal.vn</p>
          </div>
        </div>
        
        <div class="border-t border-white/10 pt-8 text-center text-white/40 text-xs">
          <p>&copy; {new URL(Astro.url).hostname}. {new Date().getFullYear()} All rights reserved.</p>
        </div>
      </div>
    </footer>

    <style is:global>
      /* Định nghĩa các quy tắc chung cho toàn bộ site */
      h1, h2, h3, h4, h5, h6 {
        @apply font-heading tracking-tight;
      }
      
      /* Tối ưu cuộn trang mượt mà */
      html {
        scroll-behavior: smooth;
      }

      /* Custom scrollbar kiểu hiện đại cho hợp với tone Đen - Vàng */
      ::-webkit-scrollbar {
        width: 8px;
      }
      ::-webkit-scrollbar-track {
        @apply bg-primary;
      }
      ::-webkit-scrollbar-thumb {
        @apply bg-secondary rounded-full;
      }
    </style>
  </body>
</html>
