---
const slides = [
  {
    title: "Gia công cắt decal chuyên nghiệp",
    sub: "Độ chính xác tuyệt đối trên mọi chất liệu decal màu, phản quang và chuyển nhiệt.",
    bg: "bg-[#2D3436]",
    cta: "Xem báo giá",
    link: "/bao-gia"
  },
  {
    title: "Giải pháp tem nhãn toàn quốc",
    sub: "Hỗ trợ chốt file online và đóng gói chuyên dụng gửi hàng tận nơi khắp các tỉnh thành.",
    bg: "bg-[#0984e3]",
    cta: "Gửi file ngay",
    link: "https://zalo.me/0862208108"
  }
];
---

<section class="relative h-[500px] md:h-[650px] overflow-hidden bg-black">
  <div id="slider-container" class="h-full flex transition-transform duration-700 ease-in-out">
    {slides.map((slide) => (
      <div class={`w-full h-full flex-shrink-0 flex items-center justify-center ${slide.bg} relative`}>
        <div class="absolute inset-0 opacity-10 bg-[url('/grid.svg')] bg-center"></div>
        
        <div class="max-w-5xl mx-auto px-4 text-center relative z-10">
          <h2 class="text-4xl md:text-7xl text-white font-bold leading-tight mb-6 tracking-tighter">
            {slide.title}
          </h2>
          <div class="w-20 h-1.5 bg-primary mx-auto mb-8"></div>
          <p class="text-gray-200 text-lg md:text-2xl max-w-3xl mx-auto mb-10 leading-relaxed">
            {slide.sub}
          </p>
          <a href={slide.link} class="inline-block bg-white text-black px-10 py-4 rounded-full font-bold hover:bg-primary hover:text-white transition-all shadow-2xl">
            {slide.cta}
          </a>
        </div>
      </div>
    ))}
  </div>

  <button id="prev-slide" class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full border border-white/20 text-white flex items-center justify-center hover:bg-white/10 transition-all">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
  </button>
  <button id="next-slide" class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full border border-white/20 text-white flex items-center justify-center hover:bg-white/10 transition-all">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
  </button>
</section>

<script>
  let currentSlide = 0;
  const container = document.getElementById('slider-container');
  const slides = container?.children.length || 0;

  function updateSlider() {
    if (container) {
      container.style.transform = `translateX(-${currentSlide * 100}%)`;
    }
  }

  document.getElementById('next-slide')?.addEventListener('click', () => {
    currentSlide = (currentSlide + 1) % slides;
    updateSlider();
  });

  document.getElementById('prev-slide')?.addEventListener('click', () => {
    currentSlide = (currentSlide - 1 + slides) % slides;
    updateSlider();
  });

  // Tự động chạy slide sau 5 giây
  setInterval(() => {
    currentSlide = (currentSlide + 1) % slides;
    updateSlider();
  }, 5000);
</script>
