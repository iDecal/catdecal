---
const slides = [
  {
    title: "Gia công cắt decal chuyên nghiệp",
    sub: "Độ chính xác tuyệt đối trên mọi chất liệu decal màu, phản quang và chuyển nhiệt.",
    img: "https://images.unsplash.com/photo-1612815154858-60aa4c59eaa6?q=80&w=1600&auto=format&fit=crop",
    cta: "Xem báo giá",
    link: "/bao-gia"
  },
  {
    title: "Giải pháp tem nhãn toàn quốc",
    sub: "Hỗ trợ chốt file online và đóng gói chuyên dụng gửi hàng tận nơi khắp các tỉnh thành.",
    img: "https://images.unsplash.com/photo-1589939705384-5185137a7f0f?q=80&w=1600&auto=format&fit=crop",
    cta: "Gửi file ngay",
    link: "https://zalo.me/0862208108"
  },
  {
    title: "Interior Film & Dán kính",
    sub: "Nâng tầm thẩm mỹ không gian sống với vật liệu phim dán nội thất cao cấp.",
    img: "https://images.unsplash.com/photo-1616489953149-8f6f691bc73a?q=80&w=1600&auto=format&fit=crop",
    cta: "Mẫu vật liệu",
    link: "/vat-lieu"
  }
];
---

<section class="relative h-[550px] md:h-[700px] overflow-hidden bg-white">
  <div id="slider-container" class="h-full flex transition-transform duration-1000 ease-in-out">
    {slides.map((slide) => (
      <div class="w-full h-full flex-shrink-0 relative">
        <div class="absolute inset-0">
          <img src={slide.img} alt={slide.title} class="w-full h-full object-cover" />
          <div class="absolute inset-0 bg-slate-900/40 mix-blend-multiply"></div>
          <div class="absolute inset-0 bg-secondary/10 backdrop-blur-[2px]"></div>
        </div>
        
        <div class="container mx-auto h-full flex items-center justify-center px-4">
          <div class="max-w-4xl text-center relative z-10">
            <h2 class="text-white mb-6 leading-[1.1]">
              {slide.title}
            </h2>
            <div class="w-16 h-1 bg-secondary mx-auto mb-8 rounded-full"></div>
            <p class="text-white/90 text-lg md:text-xl max-w-2xl mx-auto mb-12">
              {slide.sub}
            </p>
            <a href={slide.link} class="inline-block bg-white text-slate-900 px-10 py-4 rounded-xl font-bold text-xs uppercase tracking-[0.2em] hover:bg-secondary hover:text-white transition-all shadow-xl">
              {slide.cta}
            </a>
          </div>
        </div>
      </div>
    ))}
  </div>

  <button id="prev-slide" class="absolute left-6 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full border border-white/30 text-white flex items-center justify-center hover:bg-white hover:text-slate-900 transition-all z-20">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path></svg>
  </button>
  <button id="next-slide" class="absolute right-6 top-1/2 -translate-y-1/2 w-12 h-12 rounded-full border border-white/30 text-white flex items-center justify-center hover:bg-white hover:text-slate-900 transition-all z-20">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
  </button>

  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex gap-3 z-20">
    {slides.map((_, i) => (
      <div class={`slide-dot w-2 h-2 rounded-full border border-white/50 transition-all ${i === 0 ? 'bg-white w-6' : ''}`} data-index={i}></div>
    ))}
  </div>
</section>

<script>
  let currentSlide = 0;
  const container = document.getElementById('slider-container');
  const dots = document.querySelectorAll('.slide-dot');
  const slidesCount = container?.children.length || 0;

  function updateSlider() {
    if (container) {
      container.style.transform = `translateX(-${currentSlide * 100}%)`;
      // Cập nhật dots
      dots.forEach((dot, index) => {
        if (index === currentSlide) {
          dot.classList.add('bg-white', 'w-6');
        } else {
          dot.classList.remove('bg-white', 'w-6');
        }
      });
    }
  }

  document.getElementById('next-slide')?.addEventListener('click', () => {
    currentSlide = (currentSlide + 1) % slidesCount;
    updateSlider();
  });

  document.getElementById('prev-slide')?.addEventListener('click', () => {
    currentSlide = (currentSlide - 1 + slidesCount) % slidesCount;
    updateSlider();
  });

  // Tự động chạy slide sau 6 giây
  setInterval(() => {
    currentSlide = (currentSlide + 1) % slidesCount;
    updateSlider();
  }, 6000);
</script>
