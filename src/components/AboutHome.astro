---
const steps = [
  { n: "01", title: "Gửi File & Tư vấn", desc: "Tiếp nhận file Vector (AI, Corel). Hỗ trợ fix lỗi file hoàn toàn miễn phí." },
  { n: "02", title: "Báo Giá & Cọc", desc: "Minh bạch chi phí vật liệu và công cắt. Không phát sinh phí ẩn." },
  { n: "03", title: "Gia Công Siêu Tốc", desc: "Hệ thống máy cắt Nhật Bản đảm bảo đường nét sắc sảo, không răng cưa." },
  { n: "04", title: "Đóng Gói Chuyên Nghiệp", desc: "Cuộn tròn trong ống PVC cứng, đảm bảo decal không bị nhăn gãy khi ship xa." }
];
---
<section class="py-20 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-20">
      <h2>Quy trình chuyên nghiệp</h2>
      <div class="w-16 h-1 bg-secondary/30 mx-auto mt-4 rounded-full"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 lg:gap-16">
      {steps.map(step => (
        <div class="relative group">
          <span class="text-7xl font-bold text-slate-50 absolute -top-12 -left-2 z-0 transition-colors group-hover:text-secondary/10 selection:bg-transparent">
            {step.n}
          </span>
          
          <div class="relative z-10">
            <h3>{step.title}</h3>
            <p>{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
