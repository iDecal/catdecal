---
const steps = [
  { n: "01", title: "Gửi File & Tư vấn", desc: "Tiếp nhận file Vector (AI, Corel). Hỗ trợ fix lỗi file hoàn toàn miễn phí." },
  { n: "02", title: "Báo Giá & Cọc", desc: "Minh bạch chi phí vật liệu và công cắt. Không phát sinh phí ẩn." },
  { n: "03", title: "Gia Công Siêu Tốc", desc: "Hệ thống máy cắt Nhật Bản đảm bảo đường nét sắc sảo, không răng cưa." },
  { n: "04", title: "Đóng Gói Chuyên Nghiệp", desc: "Cuộn tròn trong ống PVC cứng, đảm bảo decal không bị nhăn gãy khi ship xa." }
];
---
<section class="py-24 bg-white">
  <div class="container mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-3xl font-black italic uppercase text-black">Quy trình chuyên nghiệp</h2>
      <div class="w-20 h-1.5 bg-primary mx-auto mt-4"></div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      {steps.map(step => (
        <div class="relative group">
          <span class="text-6xl font-black text-slate-100 absolute -top-10 -left-4 group-hover:text-primary/10 transition-colors">{step.n}</span>
          <div class="relative z-10">
            <h3 class="text-lg font-bold text-black mb-3 italic uppercase">{step.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{step.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
