---
const faqs = [
  { q: "Có ship hàng về tỉnh không?", a: "Chúng tôi đóng hàng trong lõi cứng bảo vệ và ship COD toàn quốc qua GHTK, Viettel Post." },
  { q: "Xưởng nhận các loại file nào?", a: "Chúng tôi ưu tiên file vector (AI, PDF, CDR, EPS) để đảm bảo độ sắc nét cao nhất khi cắt." },
  { q: "Thời gian gia công mất bao lâu?", a: "Với đơn hàng nhỏ, chúng tôi có thể gửi đi ngay trong ngày. Đơn hàng lớn từ 1-2 ngày làm việc." }
];
---
<section class="py-20 bg-white">
  <div class="container mx-auto px-4 max-w-4xl">
    <div class="text-center mb-12">
      <h2 class="text-2xl font-heading font-bold italic text-primary uppercase">Hỏi đáp dịch vụ</h2>
      <p class="text-xs text-copy-muted mt-2">Giải đáp nhanh các thắc mắc về giao nhận và kỹ thuật</p>
    </div>
    
    <div class="space-y-4">
      {faqs.map(f => (
        <details class="group bg-slate-50 border border-slate-100 rounded-xl transition-all">
          <summary class="p-5 cursor-pointer font-bold text-sm text-primary group-open:bg-primary group-open:text-secondary list-none flex justify-between items-center outline-none">
            {f.q} 
            <span class="text-[10px] group-open:rotate-180 transition-transform">▼</span>
          </summary>
          <div class="p-5 text-xs text-copy-muted leading-relaxed border-t border-slate-200 bg-white">
            {f.a}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
