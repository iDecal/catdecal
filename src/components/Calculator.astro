---
// src/components/Calculator.astro
const materials = [
  { id: 'decal-mau', name: 'Decal Màu (Quảng cáo)', price: 15000, unit: 'm tới', width: '60cm' },
  { id: 'decal-mo', name: 'Decal Mờ (Dán kính)', price: 12000, unit: 'm tới', width: '1.2m' },
  { id: 'phan-quang', name: 'Decal Phản Quang', price: 45000, unit: 'm tới', width: '60cm' },
  { id: 'tem-nhan', name: 'Bế Tem Nhãn (Dưới 5cm)', price: 250, unit: 'con tem', width: 'A4/m' },
  { id: 'chuyen-nhiet', name: 'Decal Chuyển Nhiệt (Ép áo)', price: 35000, unit: 'm tới', width: '50cm' },
];
---

<section class="bg-surface p-6 md:p-8 rounded-custom shadow-xl border border-divider max-w-4xl mx-auto my-10">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
    
    <div class="space-y-6">
      <h2 class="text-2xl font-bold text-secondary flex items-center gap-2">
        <span class="w-2 h-8 bg-primary rounded-full"></span>
        Tính giá nhanh
      </h2>

      <div>
        <label class="block text-sm font-bold text-copy mb-2 uppercase tracking-wide">Loại vật liệu</label>
        <select id="calc-material" class="w-full p-4 bg-background border border-divider rounded-lg focus:ring-2 focus:ring-primary outline-none appearance-none">
          {materials.map(m => (
            <option value={m.price} data-name={m.name} data-unit={m.unit} data-width={m.width}>
              {m.name} (Khổ {m.width})
            </option>
          ))}
        </select>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-bold text-copy mb-2 uppercase tracking-wide" id="label-qty">Số lượng (m tới)</label>
          <input type="number" id="calc-qty" value="1" min="1" class="w-full p-4 bg-background border border-divider rounded-lg focus:ring-2 focus:ring-primary outline-none" />
        </div>
        <div>
          <label class="block text-sm font-bold text-copy mb-2 uppercase tracking-wide">Yêu cầu thêm</label>
          <select id="calc-addon" class="w-full p-4 bg-background border border-divider rounded-lg focus:ring-2 focus:ring-primary outline-none">
            <option value="0">Chỉ cắt gia công</option>
            <option value="5000">Cắt + Lột nền (+5k/m)</option>
          </select>
        </div>
      </div>
    </div>

    <div class="bg-secondary rounded-2xl p-8 text-white flex flex-col justify-between shadow-2xl relative overflow-hidden">
      <div class="relative z-10">
        <p class="text-gray-400 uppercase text-xs font-bold tracking-[0.2em] mb-4">Ước tính chi phí</p>
        <div class="flex items-baseline gap-2">
          <span id="display-total" class="text-6xl font-black text-primary">0</span>
          <span class="text-2xl font-bold text-primary">đ</span>
        </div>
        
        <div class="mt-8 space-y-3 pt-6 border-t border-white/10">
          <p id="summary-text" class="text-sm text-gray-300 leading-relaxed"></p>
        </div>
      </div>

      <button id="zalo-order-btn" class="mt-8 w-full bg-primary hover:bg-primary-dark text-white font-bold py-4 rounded-xl shadow-lg transition-all transform hover:-translate-y-1 flex items-center justify-center gap-2">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2C6.48 2 2 6.48 2 12c0 1.54.36 3.04 1 4.39L2 22l5.61-1c1.35.64 2.85 1 4.39 1 5.52 0 10-4.48 10-10S17.52 2 12 2z"/></svg>
        GỬI FILE & CHỐT ĐƠN
      </button>

      <div class="absolute -bottom-10 -right-10 w-40 h-40 bg-primary/10 rounded-full blur-3xl"></div>
    </div>
  </div>
</section>

<script>
  const matSelect = document.getElementById('calc-material');
  const qtyInput = document.getElementById('calc-qty');
  const addonSelect = document.getElementById('calc-addon');
  const totalDisplay = document.getElementById('display-total');
  const summaryDisplay = document.getElementById('summary-text');
  const zaloBtn = document.getElementById('zalo-order-btn');
  const labelQty = document.getElementById('label-qty');

  function updatePrice() {
    const price = parseInt(matSelect.value);
    const qty = parseFloat(qtyInput.value) || 0;
    const addon = parseInt(addonSelect.value);
    const selected = matSelect.options[matSelect.selectedIndex];
    
    const name = selected.getAttribute('data-name');
    const unit = selected.getAttribute('data-unit');
    const width = selected.getAttribute('data-width');

    const total = (price + addon) * qty;

    // Hiệu ứng nhảy số
    totalDisplay.innerText = total.toLocaleString('vi-VN');
    
    // Cập nhật nhãn đơn vị
    labelQty.innerText = `Số lượng (${unit})`;

    // Cập nhật mô tả
    summaryDisplay.innerHTML = `
      Vật liệu: <strong>${name}</strong><br>
      Khổ: <strong>${width}</strong><br>
      Đơn giá: <strong>${(price + addon).toLocaleString()}đ/${unit}</strong>
    `;

    // Cấu hình link Zalo
    const message = `Chào catdecal.vn, tôi muốn đặt cắt gia công:\n- Loại: ${name}\n- Số lượng: ${qty} ${unit}\n- Tạm tính: ${total.toLocaleString()}đ\nNhờ xưởng kiểm tra file giúp tôi!`;
    zaloBtn.onclick = () => {
      window.open(`https://zalo.me/SĐT_CỦA_BẠN?text=${encodeURIComponent(message)}`, '_blank');
    };
  }

  matSelect.addEventListener('change', updatePrice);
  qtyInput.addEventListener('input', updatePrice);
  addonSelect.addEventListener('change', updatePrice);

  // Chạy lần đầu
  updatePrice();
</script>
