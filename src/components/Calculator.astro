<section class="bg-surface p-6 md:p-8 rounded-custom shadow-xl border border-divider max-w-4xl mx-auto my-10">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
    
    <div class="space-y-6">
      <h2 class="text-2xl font-bold text-secondary flex items-center gap-2">
        <span class="w-2 h-8 bg-primary rounded-full"></span>
        Tính giá theo kích thước
      </h2>

      <div>
        <label class="block text-sm font-bold text-copy mb-2 uppercase tracking-wide">1. Loại vật liệu & Khổ máy</label>
        <select id="calc-material" class="w-full p-4 bg-background border border-divider rounded-lg focus:ring-2 focus:ring-primary outline-none appearance-none">
          <option value="15000" data-name="Decal Màu" data-unit="m tới" data-width="60">Decal Màu (Khổ 60cm)</option>
          <option value="12000" data-name="Decal Mờ" data-unit="m tới" data-width="120">Decal Mờ (Khổ 120cm)</option>
          <option value="45000" data-name="Decal Phản Quang" data-unit="m tới" data-width="60">Decal Phản Quang (Khổ 60cm)</option>
        </select>
        <p class="text-[10px] text-copy-muted mt-1">* Lưu ý: Chiều rộng file không được vượt quá khổ máy.</p>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-bold text-copy mb-2">Rộng file (cm)</label>
          <input type="number" id="file-width" value="50" class="w-full p-4 bg-background border border-divider rounded-lg outline-none focus:border-primary" />
        </div>
        <div>
          <label class="block text-sm font-bold text-copy mb-2">Cao file (cm)</label>
          <input type="number" id="file-height" value="100" class="w-full p-4 bg-background border border-divider rounded-lg outline-none focus:border-primary" />
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-bold text-copy mb-2 uppercase tracking-wide">Số lượng (tấm)</label>
          <input type="number" id="file-count" value="1" min="1" class="w-full p-4 bg-background border border-divider rounded-lg focus:ring-2 focus:ring-primary outline-none" />
        </div>
        <div>
          <label class="block text-sm font-bold text-copy mb-2 uppercase tracking-wide">Làm tròn</label>
          <select id="round-type" class="w-full p-4 bg-background border border-divider rounded-lg outline-none">
            <option value="standard">Để lẻ (0.1m)</option>
            <option value="up">Lên mét nguyên</option>
          </select>
        </div>
      </div>
    </div>

    <div class="bg-secondary rounded-2xl p-8 text-white flex flex-col justify-between shadow-2xl">
      <div>
        <p class="text-gray-400 uppercase text-xs font-bold tracking-widest mb-4">Kết quả quy đổi</p>
        <div class="flex items-baseline gap-2 mb-2">
          <span id="display-met" class="text-4xl font-bold text-white">0</span>
          <span class="text-xl text-gray-400">mét tới</span>
        </div>
        <div class="flex items-baseline gap-2">
          <span id="display-total" class="text-6xl font-black text-primary">0</span>
          <span class="text-2xl font-bold text-primary">đ</span>
        </div>
        
        <div id="summary-text" class="mt-8 pt-6 border-t border-white/10 text-sm text-gray-300 space-y-1">
          </div>
      </div>

      <button id="zalo-order-btn" class="mt-8 w-full bg-primary hover:bg-primary-dark text-white font-bold py-4 rounded-xl shadow-lg transition-all flex items-center justify-center gap-2 uppercase">
        Gửi yêu cầu qua Zalo
      </button>
    </div>
  </div>
</section>

<script>
  function initCalculator() {
    const matSelect = document.getElementById('calc-material');
    const fWidth = document.getElementById('file-width');
    const fHeight = document.getElementById('file-height');
    const fCount = document.getElementById('file-count');
    const roundType = document.getElementById('round-type');
    
    const totalDisplay = document.getElementById('display-total');
    const metDisplay = document.getElementById('display-met');
    const summaryDisplay = document.getElementById('summary-text');
    const zaloBtn = document.getElementById('zalo-order-btn');

    function calculate() {
      const pricePerMet = parseInt(matSelect.value);
      const width = parseFloat(fWidth.value) || 0;
      const height = parseFloat(fHeight.value) || 0;
      const count = parseInt(fCount.value) || 0;
      const selectedMat = matSelect.options[matSelect.selectedIndex];
      const maxMachineWidth = parseFloat(selectedMat.getAttribute('data-width'));

      // 1. Kiểm tra khổ máy
      if (width > maxMachineWidth) {
        fWidth.classList.add('border-primary', 'text-primary');
      } else {
        fWidth.classList.remove('border-primary', 'text-primary');
      }

      // 2. Tính số mét tới (Chiều cao * số lượng / 100)
      let metToi = (height * count) / 100;

      // 3. Logic làm tròn
      if (roundType.value === 'up') {
        metToi = Math.ceil(metToi); // 1.2 -> 2
      } else {
        metToi = Math.round(metToi * 10) / 10; // 1.23 -> 1.2
      }

      if (metToi < 1 && metToi > 0) metToi = 1; // Tối thiểu 1 mét tới để bõ công cắt

      const total = metToi * pricePerMet;

      // 4. Hiển thị
      metDisplay.innerText = metToi;
      totalDisplay.innerText = total.toLocaleString('vi-VN');
      
      summaryDisplay.innerHTML = `
        <p>Vật liệu: <strong>${selectedMat.getAttribute('data-name')}</strong></p>
        <p>Kích thước: <strong>${width}x${height} cm</strong> (x${count} tấm)</p>
        <p>Quy cách: <strong>${metToi} mét tới</strong></p>
      `;

      // 5. Link Zalo
      const msg = `Báo giá catdecal.vn:\n- ${selectedMat.getAttribute('data-name')}\n- Kích thước: ${width}x${height}cm\n- Số lượng: ${count} tấm\n- Quy đổi: ${metToi} mét tới\n- Tạm tính: ${total.toLocaleString()}đ`;
      zaloBtn.onclick = () => window.open(`https://zalo.me/SĐT_CỦA_BẠN?text=${encodeURIComponent(msg)}`, '_blank');
    }

    [matSelect, fWidth, fHeight, fCount, roundType].forEach(el => el.addEventListener('input', calculate));
    calculate();
  }

  initCalculator();
  document.addEventListener('astro:after-swap', initCalculator);
</script>
