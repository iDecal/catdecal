---
---
<section id="calculator" class="py-24 bg-white">
  <div class="container mx-auto px-4">
    <div class="max-w-5xl mx-auto grid grid-cols-1 lg:grid-cols-5 bg-primary rounded-[2.5rem] shadow-2xl overflow-hidden">
      <div class="lg:col-span-3 bg-white p-8 md:p-12 space-y-6 text-primary border-r border-slate-100">
        <h2 class="text-2xl font-heading font-bold italic mb-8 uppercase tracking-tight">1. Thông số cắt</h2>
        <div class="grid grid-cols-2 gap-6">
          <div class="col-span-2 space-y-2">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Loại vật liệu</label>
            <select id="mat" class="w-full p-4 rounded-xl bg-slate-50 border-none outline-none focus:ring-2 focus:ring-secondary transition-all">
              <option value="120000">Decal Mờ (Văn phòng)</option>
              <option value="450000">Decal Phản Quang 3M</option>
              <option value="180000">Decal Trong/Sữa</option>
              <option value="150000">Decal Màu (Thường)</option>
            </select>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Chiều dài (cm)</label>
            <input type="number" id="L" placeholder="0" class="w-full p-4 rounded-xl bg-slate-50 border-none outline-none focus:ring-2 focus:ring-secondary transition-all" />
          </div>
          <div class="space-y-2">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Chiều rộng (cm)</label>
            <input type="number" id="W" placeholder="0" class="w-full p-4 rounded-xl bg-slate-50 border-none outline-none focus:ring-2 focus:ring-secondary transition-all" />
          </div>
          <div class="col-span-2 space-y-2">
            <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Số lượng</label>
            <input type="number" id="Qty" value="1" class="w-full p-4 rounded-xl bg-slate-50 border-none outline-none focus:ring-2 focus:ring-secondary transition-all" />
          </div>
        </div>
        <button id="calc" class="w-full bg-primary text-secondary font-black p-5 rounded-xl hover:brightness-125 transition-all shadow-lg shadow-primary/20 uppercase tracking-widest">
          XEM BÁO GIÁ DỰ KIẾN
        </button>
      </div>

      <div class="lg:col-span-2 p-8 md:p-12 flex flex-col justify-center text-white bg-primary relative overflow-hidden">
        <div class="relative z-10">
          <h2 class="text-xl font-heading font-bold text-secondary mb-4 italic uppercase">2. Kết quả & Gửi file</h2>
          <div id="resBox" class="hidden mb-8 animate-in fade-in duration-500">
            <span class="text-white/40 text-[10px] uppercase block mb-1">Tổng cộng ước tính:</span>
            <div id="price" class="text-5xl font-black text-secondary tracking-tighter">0đ</div>
          </div>
          <div class="border-2 border-dashed border-white/10 rounded-2xl p-6 text-center group relative hover:border-secondary transition-all cursor-pointer">
            <input type="file" id="fUp" class="absolute inset-0 opacity-0 cursor-pointer" />
            <div class="space-y-2">
              <svg class="w-8 h-8 mx-auto text-white/20 group-hover:text-secondary transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path></svg>
              <p class="text-xs font-bold text-white uppercase tracking-tight italic">Tải file AI / PDF / CDR</p>
            </div>
            <p id="fName" class="text-[10px] text-secondary mt-3 italic truncate"></p>
          </div>
          <button class="mt-8 w-full bg-white text-primary font-black p-4 rounded-xl hover:bg-secondary transition-all flex items-center justify-center gap-2">
            GỬI ĐƠN QUA ZALO
          </button>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const btn = document.getElementById('calc');
  const price = document.getElementById('price');
  const resBox = document.getElementById('resBox');
  const fUp = document.getElementById('fUp') as HTMLInputElement;
  const fName = document.getElementById('fName');

  fUp?.addEventListener('change', (e) => {
    const file = (e.target as HTMLInputElement).files?.[0];
    if (file && fName) {
        fName.innerText = `📄 Đã chọn: ${file.name}`;
    }
  });

  btn?.addEventListener('click', () => {
    const rate = parseFloat((document.getElementById('mat') as HTMLSelectElement).value);
    const l = parseFloat((document.getElementById('L') as HTMLInputElement).value) || 0;
    const w = parseFloat((document.getElementById('W') as HTMLInputElement).value) || 0;
    const q = parseFloat((document.getElementById('Qty') as HTMLInputElement).value) || 1;
    
    let total = (l * w / 10000) * rate * q;
    
    // Giá sàn 30k cho các đơn quá nhỏ
    if (total > 0 && total < 30000) total = 30000;

    if (l > 0 && w > 0) {
      price!.innerText = new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(total);
      resBox?.classList.remove('hidden');
      resBox?.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  });
</script>
