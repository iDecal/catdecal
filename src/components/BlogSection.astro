---
// Dữ liệu bài viết tập trung vào chuyên môn kỹ thuật và quy trình giao hàng toàn quốc
const posts = [
  {
    title: "Hướng dẫn chuẩn bị file vector chuẩn cho máy cắt decal",
    excerpt: "Làm sao để đường cắt sắc nét và không bị răng cưa? Khám phá cách xuất file .AI và .Corel chuẩn kỹ thuật để gia công từ xa.",
    image: "https://images.unsplash.com/photo-1572044162444-ad60f128bde7?auto=format&fit=crop&q=80&w=600",
    date: "15/04/2026",
    link: "/blog/chuan-bi-file-vector"
  },
  {
    title: "Giải pháp đóng gói decal gửi tỉnh đảm bảo không gãy nếp",
    excerpt: "Quy trình sử dụng ống nhựa PVC và màng PE chuyên dụng giúp sản phẩm đến tay khách hàng toàn quốc luôn hoàn hảo.",
    image: "https://images.unsplash.com/photo-1566197730469-510629d8a042?auto=format&fit=crop&q=80&w=600",
    date: "12/04/2026",
    link: "/blog/quy-trinh-dong-goi"
  },
  {
    title: "Sự khác biệt giữa Decal sữa và Decal trong trong quảng cáo",
    excerpt: "Lựa chọn loại chất liệu phù hợp giúp tăng độ bền màu và tính thẩm mỹ cho biển hiệu của bạn dù ở bất kỳ đâu.",
    image: "https://images.unsplash.com/photo-1626785774573-4b799315345d?auto=format&fit=crop&q=80&w=600",
    date: "10/04/2026",
    link: "/blog/phan-biet-decal"
  }
];
---

<section class="py-20 bg-white">
  <div class="max-w-7xl mx-auto px-4">
    <div class="flex justify-between items-end mb-12">
      <div>
        <h2 class="text-3xl text-black mb-2">Chia sẻ kinh nghiệm gia công</h2>
        <div class="w-12 h-1 bg-primary"></div>
      </div>
      <a href="/blog" class="text-sm font-bold text-primary hover:underline transition-all">
        Xem tất cả bài viết →
      </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {posts.map((post) => (
        <article class="group cursor-pointer">
          <div class="aspect-[16/10] overflow-hidden rounded-xl border border-divider mb-5">
            <img 
              src={post.image} 
              alt={post.title} 
              class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
            />
          </div>
          <div class="space-y-3">
            <span class="text-xs font-bold text-gray-400 uppercase tracking-widest">{post.date}</span>
            <h3 class="text-xl text-black group-hover:text-primary transition-colors leading-snug">
              <a href={post.link}>{post.title}</a>
            </h3>
            <p class="text-gray-500 text-sm leading-relaxed line-clamp-2">
              {post.excerpt}
            </p>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>
