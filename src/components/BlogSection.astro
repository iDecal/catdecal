---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 3);
---

<section class="py-20 md:py-32 bg-[#f0f9ff] overflow-hidden">
  <div class="max-w-7xl mx-auto px-6">
    
    <div class="flex justify-between items-end mb-12 md:mb-16">
      <div>
        <h2 class="text-2xl md:text-4xl tracking-tight text-slate-900 mb-3">
          Chia sẻ kinh nghiệm
        </h2>
        <div class="w-16 h-1 bg-secondary rounded-full"></div>
      </div>

      <a href="/blog" class="text-sm md:text-lg font-bold text-secondary hover:text-slate-900 transition-all flex items-center gap-2 border-b-2 border-secondary/30 pb-1 md:pb-2 hover:border-slate-900">
        Xem tất cả <span class="text-xl md:text-2xl">→</span>
      </a>
    </div>

    <div class="flex md:grid md:grid-cols-3 gap-8 md:gap-12 overflow-x-auto md:overflow-visible snap-x snap-mandatory scrollbar-hide -mx-6 px-6 md:mx-0 md:px-0">
      {latestPosts.map((post) => (
        <article class="min-w-[88%] md:min-w-0 snap-start group flex flex-col">
          <a href={`/blog/${post.slug}`} class="relative block aspect-[16/10] overflow-hidden rounded-[2rem] mb-8 shadow-xl shadow-blue-900/5">
            <img 
              src={post.data.image} 
              alt={post.data.title} 
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
            />
            <div class="absolute top-6 left-6 bg-white/90 backdrop-blur-sm px-4 py-1.5 rounded-full text-[10px] font-bold text-secondary uppercase tracking-widest shadow-sm">
              {post.data.category}
            </div>
          </a>

          <div class="flex flex-col flex-1 px-2">
            <span class="text-[11px] font-bold text-slate-300 uppercase tracking-[0.2em] mb-4">{post.data.date}</span>
            <h3 class="text-2xl md:text-xl font-bold text-slate-900 group-hover:text-secondary transition-colors leading-tight mb-4">
              <a href={`/blog/${post.slug}`}>{post.data.title}</a>
            </h3>
            <p class="text-slate-500 text-[16px] md:text-sm leading-relaxed line-clamp-2 mb-8">
              {post.data.excerpt}
            </p>
            <a href={`/blog/${post.slug}`} class="mt-auto text-[11px] font-black uppercase tracking-[0.2em] text-slate-900 flex items-center gap-2 group-hover:text-secondary group-hover:gap-4 transition-all">
              KHÁM PHÁ <span class="text-xl">→</span>
            </a>
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  /* Reset nhẹ để đảm bảo CSS global của bạn không bị ghi đè bởi các thuộc tính font mặc định của trình duyệt */
  h2, a {
    font-style: normal;
    text-transform: none;
  }
</style>
