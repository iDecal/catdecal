---
// src/components/Hero.astro
---

<section class="relative bg-surface overflow-hidden pt-16 md:pt-20">
  <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/4 w-96 h-96 bg-primary/5 rounded-full blur-3xl"></div>
  
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="flex flex-col lg:flex-row items-center gap-12 py-12 md:py-24">
      
      <div class="lg:w-1/2 text-center lg:text-left">
        <div class="inline-flex items-center px-4 py-2 rounded-full bg-primary/10 text-primary text-sm font-bold mb-6">
          <span class="flex h-2 w-2 rounded-full bg-primary animate-ping mr-2"></span>
          Xưởng gia công cắt lấy ngay
        </div>

        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-copy leading-tight mb-6">
          Dịch Vụ <span class="text-primary">Cắt Decal</span> Theo Yêu Cầu Tại TP.HCM
        </h1>

        <p class="text-lg text-copy-light mb-8 max-w-xl mx-auto lg:mx-0">
          Chuyên gia công cắt chữ decal quảng cáo, sticker, tem bế và decal trang trí chính xác từng mm. Hỗ trợ cán màng định hình, <strong>lấy ngay trong ngày</strong> tại Thủ Đức và các khu vực lân cận.
        </p>

        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
          <a
            href="/bao-gia"
            class="px-8 py-4 bg-primary hover:bg-primary-dark text-white rounded-xl font-bold text-lg shadow-lg shadow-primary/20 transition-all transform hover:-translate-y-1"
          >
            Nhận báo giá cắt nhanh
          </a>
          <a
            href="/thu-vien"
            class="px-8 py-4 bg-white border border-divider text-copy hover:border-primary hover:text-primary rounded-xl font-bold text-lg transition-all"
          >
            Xem mẫu đã cắt
          </a>
        </div>

        <div class="mt-10 flex flex-wrap justify-center lg:justify-start gap-6 border-t border-divider pt-8">
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
            <span class="text-sm font-medium text-copy">Chính xác 100%</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
            <span class="text-sm font-medium text-copy">Cắt lấy liền</span>
          </div>
          <div class="flex items-center gap-2">
            <svg class="w-5 h-5 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            <span class="text-sm font-medium text-copy">Đa dạng vật liệu</span>
          </div>
        </div>
      </div>

      <div class="lg:w-1/2 relative group">
        <div class="absolute -inset-4 bg-primary/10 rounded-3xl rotate-3 group-hover:rotate-0 transition-transform"></div>
        <div class="relative bg-white p-2 rounded-2xl border border-divider shadow-2xl">
          <img 
            src="/images/may-cat-decal-chuyen-nghiep.webp" 
            alt="Máy cắt bế decal chuyên nghiệp tại xưởng catdecal.vn" 
            class="rounded-xl w-full h-auto"
            loading="eager"
            width="600"
            height="450"
          />
          <div class="absolute bottom-6 right-6 bg-white/90 backdrop-blur px-4 py-2 rounded-lg shadow-lg border-l-4 border-primary">
             <p class="text-[10px] uppercase font-bold text-primary">Sản phẩm thực tế</p>
             <p class="text-sm font-bold text-copy">Cắt chữ decal dán kính</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
