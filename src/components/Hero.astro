---
---
<section class="relative h-[75vh] flex items-center bg-primary overflow-hidden">
  <div class="absolute inset-0 z-0 opacity-40">
    <img src="https://images.unsplash.com/photo-1611532736597-de2d4265fba3?q=80&w=2000" class="w-full h-full object-cover" alt="Xưởng cắt decal chuyên nghiệp" />
    <div class="absolute inset-0 bg-gradient-to-r from-primary via-primary/60 to-transparent"></div>
  </div>
  
  <div class="container mx-auto px-4 relative z-10">
    <div class="max-w-2xl">
      <div class="inline-block bg-secondary text-primary px-3 py-1 rounded-full text-[10px] font-black uppercase tracking-widest mb-6">
        Hệ thống gia công toàn quốc
      </div>
      <h1 class="text-4xl md:text-6xl font-heading font-extrabold text-white leading-[1.1] mb-6 uppercase italic">
        Cắt Decal <br/> <span class="text-secondary">Chính xác & Siêu tốc</span>
      </h1>
      <p class="text-lg text-white/70 mb-10 italic leading-relaxed max-w-lg">
        Gửi file online - Nhận hàng tận nơi. Quy trình đóng gói chuyên nghiệp chống gãy gập cho khách hàng toàn quốc.
      </p>
      <div class="flex flex-wrap gap-4">
        <a href="#calculator" class="bg-secondary text-primary px-8 py-4 rounded-xl font-black hover:scale-105 transition-all shadow-lg shadow-secondary/20">
          TÍNH GIÁ & GỬI FILE
        </a>
        <a href="https://zalo.me/your-number" class="bg-white/10 backdrop-blur-md text-white border border-white/20 px-8 py-4 rounded-xl font-bold hover:bg-white/20 transition-all">
          TƯ VẤN ZALO
        </a>
      </div>
    </div>
  </div>
</section>
