---
const socials = [
  { name: 'Facebook', url: '#', icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>` },
  { name: 'Zalo', url: 'https://zalo.me/0862208108', icon: `<svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.052 13.102l-1.076-.566c-.366-.192-.486-.464-.326-.74.137-.234.331-.44.503-.66l1.246-1.579c.143-.18.177-.354.091-.503-.092-.15-.297-.206-.526-.143l-1.926.54c-.337.091-.6-.006-.726-.309l-.783-1.897c-.097-.24-.263-.349-.474-.314-.206.028-.354.194-.4.434l-.44 2.212c-.068.343-.286.503-.611.451l-2.006-.32c-.223-.034-.411.029-.503.177-.08.131-.051.314.091.503l1.411 1.863c.2.269.183.543-.051.783l-1.634 1.674c-.177.183-.217.377-.12.526.091.149.303.183.537.08l1.92-1.074c.337-.189.594-.131.726.16l1.011 2.234c.109.24.28.349.497.32.206-.023.36-.183.411-.429l.486-2.314c.068-.343.3-.486.617-.417l2.131.463c.234.051.423-.006.514-.154.086-.143.057-.337-.091-.52zm-7.052-12.102c-6.627 0-12 5.373-12 12s5.373 12 12 12 12-5.373 12-12-5.373-12-12-12z"/></svg>` }
];
---

<footer class="bg-white text-slate-600 pt-24 pb-12 border-t border-slate-50">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12 lg:gap-20">
    
    <div class="footer-column">
      <h2 class="text-3xl font-black text-slate-900 mb-6 tracking-tighter">catdecal<span class="text-secondary">.vn</span></h2>
      <p class="text-sm leading-7 mb-8 text-slate-400">
        Hệ sinh thái iDecal - Chuyên gia gia công cắt decal và interior film tại Bình Định.
      </p>
      <div class="flex gap-4">
        {socials.map(social => (
          <a href={social.url} class="w-10 h-10 bg-slate-50 rounded-xl flex items-center justify-center text-slate-400 hover:bg-secondary hover:text-white transition-all p-2.5 shadow-sm" aria-label={social.name} set:html={social.icon}></a>
        ))}
      </div>
    </div>

    <div class="footer-accordion border-b border-slate-50 md:border-0">
      <button class="w-full flex justify-between items-center py-5 md:py-0 md:cursor-default accordion-btn">
        <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-slate-900">Dịch vụ</h3>
        <span class="md:hidden text-xl font-light text-secondary">+</span>
      </button>
      <div class="footer-content hidden md:block mt-8 pb-8 md:pb-0">
        <ul class="text-sm space-y-5">
          <li><a href="/dich-vu/cat-decal-mau" class="hover:text-secondary transition-colors">Cắt Decal quảng cáo</a></li>
          <li><a href="/dich-vu/cat-decal-mo" class="hover:text-secondary transition-colors">Cắt Decal mờ vách kính</a></li>
          <li><a href="/dich-vu/cat-be-tem-nhan" class="hover:text-secondary transition-colors">Bế tem nhãn sản phẩm</a></li>
          <li><a href="/dich-vu/cat-decal-phan-quang" class="hover:text-secondary transition-colors">Cắt Decal phản quang</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-accordion border-b border-slate-50 md:border-0">
      <button class="w-full flex justify-between items-center py-5 md:py-0 md:cursor-default accordion-btn">
        <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-slate-900">Thông tin</h3>
        <span class="md:hidden text-xl font-light text-secondary">+</span>
      </button>
      <div class="footer-content hidden md:block mt-8 pb-8 md:pb-0">
        <ul class="text-sm space-y-5">
          <li><a href="/blog" class="hover:text-secondary transition-colors">Blog kiến thức</a></li>
          <li><a href="/quy-trinh-dat-hang" class="hover:text-secondary transition-colors">Quy trình đặt hàng</a></li>
          <li><a href="/giao-hang-thanh-toan" class="hover:text-secondary transition-colors">Giao hàng & Thanh toán</a></li>
          <li><a href="#" class="hover:text-secondary transition-colors">Chính sách dịch vụ</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-accordion md:border-0">
      <button class="w-full flex justify-between items-center py-5 md:py-0 md:cursor-default accordion-btn">
        <h3 class="text-[11px] font-bold uppercase tracking-[0.2em] text-slate-900">Liên hệ</h3>
        <span class="md:hidden text-xl font-light text-secondary">+</span>
      </button>
      <div class="footer-content hidden md:block mt-8 pb-8 md:pb-0">
        <p class="text-secondary font-black text-2xl mb-2 tracking-tight">0862 208 108</p>
        <p class="text-slate-400 text-[11px] tracking-wide mb-8">Zalo hỗ trợ 24/7</p>
        <div class="text-sm text-slate-500 leading-relaxed">
          <p class="font-bold text-slate-900 mb-1">Xưởng sản xuất:</p>
          <p>TP. Quy Nhơn, Tỉnh Bình Định</p>
        </div>
      </div>
    </div>

  </div>
  
  <div class="max-w-7xl mx-auto px-6 mt-24 pt-8 border-t border-slate-50 text-center">
    <p class="text-slate-300 text-[10px] font-medium tracking-[0.4em] uppercase">
      © 2026 CATDECAL.VN — iDecal Ecosystem
    </p>
  </div>
</footer>

<script>
  function setupFooter() {
    const accordions = document.querySelectorAll('.footer-accordion');
    
    accordions.forEach(item => {
      const btn = item.querySelector('.accordion-btn');
      const content = item.querySelector('.footer-content');
      const span = item.querySelector('span');

      btn?.addEventListener('click', () => {
        if (window.innerWidth < 768) {
          const isOpen = !content?.classList.contains('hidden');
          
          document.querySelectorAll('.footer-content').forEach(c => c.classList.add('hidden'));
          document.querySelectorAll('.footer-accordion span').forEach(s => s.textContent = '+');

          if (!isOpen) {
            content?.classList.remove('hidden');
            if (span) span.textContent = '−';
          }
        }
      });
    });
  }

  setupFooter();
  document.addEventListener('astro:after-swap', setupFooter);
</script>

<style>
  a { text-decoration: none; }
  @media (max-width: 767px) {
    .footer-content ul li a {
      padding: 0.6rem 0;
      display: block;
    }
  }
</style>
