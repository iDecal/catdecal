---

<section class="bg-white py-8 md:py-12 border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {commitments.map(item => (
        <div class="flex items-center gap-3 group">
          <div class="w-7 h-7 md:w-8 md:h-8 text-primary shrink-0 transition-transform group-hover:scale-110" set:html={item.icon}></div>
          <div>
            <h3 class="text-[12px] md:text-[13px] font-bold text-black uppercase tracking-tight leading-tight">{item.title}</h3>
            <p class="text-[10px] text-gray-400 hidden md:block">{item.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<footer class="bg-[#F5F5F5] text-[#2D3436] pt-10 md:pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-4 md:gap-12">
    
    <div class="footer-column mb-6 md:mb-0">
      <h2 class="text-2xl font-bold text-primary mb-3">catdecal.vn</h2>
      <p class="text-gray-500 text-sm leading-relaxed mb-6">
        Xưởng gia công cắt decal chuyên nghiệp tại Bình Định. Đảm bảo độ chính xác tuyệt đối.
      </p>
      <div class="flex gap-3">
        {socials.map(social => (
          <a href={social.url} class="w-9 h-9 bg-white rounded-full flex items-center justify-center shadow-sm text-gray-400 hover:bg-primary hover:text-white transition-all p-2" aria-label={social.name} set:html={social.icon}></a>
        ))}
      </div>
    </div>

    <div class="footer-accordion border-b border-gray-200 md:border-0">
      <button class="w-full flex justify-between items-center py-3 md:py-0 md:cursor-default accordion-btn">
        <h3 class="text-lg md:text-sm font-bold uppercase tracking-wider text-black">Dịch vụ chính</h3>
        <span class="md:hidden text-2xl font-light text-primary">+</span>
      </button>
      <div class="footer-content hidden md:block mt-2 md:mt-4 pb-4 md:pb-0">
        <ul class="text-gray-600 text-sm space-y-4 md:space-y-3">
          <li><a href="/dich-vu/cat-decal-mau" class="hover:text-primary transition-colors">Cắt Decal màu quảng cáo</a></li>
          <li><a href="/dich-vu/cat-decal-mo" class="hover:text-primary transition-colors">Cắt Decal mờ vách kính</a></li>
          <li><a href="/dich-vu/cat-be-tem-nhan" class="hover:text-primary transition-colors">Bế tem nhãn sản phẩm</a></li>
          <li><a href="/dich-vu/cat-decal-phan-quang" class="hover:text-primary transition-colors">Cắt Decal phản quang</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-accordion border-b border-gray-200 md:border-0">
      <button class="w-full flex justify-between items-center py-3 md:py-0 md:cursor-default accordion-btn">
        <h3 class="text-lg md:text-sm font-bold uppercase tracking-wider text-black">Hỗ trợ khách hàng</h3>
        <span class="md:hidden text-2xl font-light text-primary">+</span>
      </button>
      <div class="footer-content hidden md:block mt-2 md:mt-4 pb-4 md:pb-0">
        <ul class="text-gray-600 text-sm space-y-4 md:space-y-3">
          <li><a href="/quy-trinh-dat-hang" class="hover:text-primary transition-colors">Quy trình đặt hàng</a></li>
          <li><a href="/giao-hang-thanh-toan" class="hover:text-primary transition-colors">Giao hàng & Thanh toán</a></li>
          <li><a href="#" class="hover:text-primary transition-colors">Chuẩn bị file</a></li>
          <li><a href="#" class="hover:text-primary transition-colors">Chính sách bảo hành</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-accordion md:border-0">
      <button class="w-full flex justify-between items-center py-3 md:py-0 md:cursor-default accordion-btn">
        <h3 class="text-lg md:text-sm font-bold uppercase tracking-wider text-black">Thông tin liên hệ</h3>
        <span class="md:hidden text-2xl font-light text-primary">+</span>
      </button>
      <div class="footer-content hidden md:block mt-2 md:mt-4 pb-4 md:pb-0">
        <p class="text-primary font-bold text-2xl md:text-xl mb-1">0862 208 108</p>
        <p class="text-gray-600 text-sm">Zalo/Hotline hỗ trợ 24/7</p>
        <p class="text-gray-500 text-sm mt-4">
          <span class="block font-medium text-black">Xưởng sản xuất:</span>
          TP. Quy Nhơn, Tỉnh Bình Định
        </p>
      </div>
    </div>

  </div>
  
  <div class="max-w-7xl mx-auto px-4 mt-8 md:mt-16 pt-8 border-t border-gray-200 text-center">
    <p class="text-gray-400 text-xs italic">
      © 2026 catdecal.vn - iDecal Ecosystem.
    </p>
  </div>
</footer>

<script>
  function setupFooter() {
    const accordions = document.querySelectorAll('.footer-accordion');
    
    accordions.forEach(item => {
      const btn = item.querySelector('.accordion-btn');
      const content = item.querySelector('.footer-content');
      const span = item.querySelector('span');

      btn?.addEventListener('click', () => {
        if (window.innerWidth < 768) {
          const isOpen = !content?.classList.contains('hidden');
          
          // Đóng các cái khác
          document.querySelectorAll('.footer-content').forEach(c => c.classList.add('hidden'));
          document.querySelectorAll('.footer-accordion span').forEach(s => s.textContent = '+');

          if (!isOpen) {
            content?.classList.remove('hidden');
            if (span) span.textContent = '−';
          }
        }
      });
    });
  }

  setupFooter();
  document.addEventListener('astro:after-swap', setupFooter);
</script>

<style>
  /* Fix Typography */
  h2, h3, p, a, span, button {
    font-style: normal !important;
  }
  
  /* Cải thiện chạm trên Mobile */
  @media (max-width: 767px) {
    .footer-content ul li a {
      font-size: 1rem;
      padding: 0.25rem 0;
      display: block;
    }
  }
</style>
