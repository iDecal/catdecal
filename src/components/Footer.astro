---
const commitments = [
  {
    title: "Giao hàng hỏa tốc",
    desc: "Gửi hàng ngay trong ngày qua chành xe hoặc CPN",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`
  },
  {
    title: "Thanh toán linh hoạt",
    desc: "Chuyển khoản hoặc COD khi nhận hàng toàn quốc",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>`
  },
  {
    title: "Đóng gói chuyên dụng",
    desc: "Ống nhựa cứng bảo vệ decal không gãy nếp",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`
  },
  {
    title: "Hỗ trợ file kỹ thuật",
    desc: "Kiểm tra và vẽ lại file vector miễn phí",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`
  }
];
---

<section class="commitments-section">
  <div class="container">
    <div class="commitments-grid">
      {commitments.map(item => (
        <div class="commitment-card">
          <div class="icon-wrapper" set:html={item.icon}></div>
          <h3>{item.title}</h3>
          <p>{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<footer class="main-footer">
  <div class="container footer-grid">
    
    <div class="footer-brand">
      <h2>catdecal.vn</h2>
      <p>Xưởng gia công cắt decal chuyên nghiệp tại Bình Định. Đảm bảo độ chính xác trên mọi chất liệu.</p>
    </div>

    <div class="footer-links">
      <h3>Dịch vụ chính</h3>
      <ul>
        <li><a href="/dich-vu/cat-decal-mau">Cắt Decal màu quảng cáo</a></li>
        <li><a href="/dich-vu/cat-decal-mo">Cắt Decal mờ vách kính</a></li>
        <li><a href="/dich-vu/cat-be-tem-nhan">Bế tem nhãn sản phẩm</a></li>
        <li><a href="/dich-vu/cat-decal-phan-quang">Cắt Decal phản quang</a></li>
      </ul>
    </div>

    <div class="footer-links">
      <h3>Hỗ trợ khách hàng</h3>
      <ul>
        <li><a href="/quy-trinh-dat-hang">Quy trình đặt hàng</a></li>
        <li><a href="/giao-hang-thanh-toan">Giao hàng & Thanh toán</a></li>
        <li><a href="#">Hướng dẫn chuẩn bị file</a></li>
        <li><a href="#">Chính sách bảo hành</a></li>
      </ul>
    </div>

    <div class="footer-contact">
      <h3>Thông tin liên hệ</h3>
      <p class="phone">0862 208 108</p>
      <p>Zalo/Hotline hỗ trợ 24/7</p>
      <address>
        <strong>Địa chỉ xưởng:</strong><br/>
        TP. Quy Nhơn, Tỉnh Bình Định
      </address>
    </div>

  </div>
  
  <div class="footer-bottom">
    <p>© 2026 catdecal.vn - Thiết kế bởi iDecal Ecosystem.</p>
  </div>
</footer>

<style>
  /* Cấu trúc Grid cho cam kết */
  .commitments-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
  }
  @media (min-width: 768px) {
    .commitments-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  /* Cấu trúc Grid cho Footer */
  .footer-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 3rem;
  }
  @media (min-width: 768px) {
    .footer-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .icon-wrapper svg {
    width: 2rem;
    height: 2rem;
  }

  /* Đảm bảo chữ đứng chân phương theo yêu cầu của bạn */
  h1, h2, h3, p, a, span {
    font-style: normal !important;
  }
</style>
