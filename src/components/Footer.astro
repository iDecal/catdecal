---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#ffffff] border-t border-[#E2E8F0] pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      
      <div class="space-y-4">
        <h2 class="text-[#1B3A6B] text-xl font-black uppercase tracking-tighter">iDecal.vn</h2>
        <p class="text-[#475569] text-sm leading-relaxed">
          Chuyên gia cung cấp giải pháp decal dán kính, phim cách nhiệt và phim nội thất chuyên nghiệp tại khu vực phía Nam. 
        </p>
        <div class="flex gap-4">
          <a href="#" class="text-[#1B3A6B] hover:text-[#F97316] transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          </a>
          <a href="#" class="text-[#1B3A6B] hover:text-[#F97316] transition-colors">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.791.218 2.427.465a4.902 4.902 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.247.636.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.902 4.902 0 01-1.772 1.153c-.636.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.791-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.247-.636-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.218-1.791.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.636-.247 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16.362a4.2a4.2 0 110-8.399 4.2 4.2 0 010 8.399zm5.885-9.39a1.44 1.44 0 11-2.88 0 1.44 1.44 0 012.88 0z"/></svg>
          </a>
        </div>
      </div>

      <div>
        <h3 class="text-[#0F172A] font-black text-sm uppercase tracking-widest mb-6">Sản phẩm chính</h3>
        <ul class="space-y-3">
          <li><a href="/src/pages/decal-mo-3d.astro" class="text-[#475569] hover:text-[#F97316] text-sm transition-colors">Decal mờ 3D vân nổi</a></li>
          <li><a href="/src/pages/phim-cach-nhiet.astro" class="text-[#475569] hover:text-[#F97316] text-sm transition-colors">Phim cách nhiệt 3M/Llumar</a></li>
          <li><a href="/src/pages/decal-van-phong.astro" class="text-[#475569] hover:text-[#F97316] text-sm transition-colors">Dán kính mờ văn phòng</a></li>
          <li><a href="/src/pages/film-noithat.astro" class="text-[#475569] hover:text-[#F97316] text-sm transition-colors">Film dán nội thất Vinyl</a></li>
          <li><a href="/src/pages/decal-cat-chu.astro" class="text-[#475569] hover:text-[#F97316] text-sm transition-colors">Cắt chữ Decal máy CNC</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-[#0F172A] font-black text-sm uppercase tracking-widest mb-6">Liên kết nhanh</h3>
        <ul class="space-y-3">
          <li><a href="/src/pages/gioi-thieu.astro" class="text-[#475569] hover:text-[#F97316] text-sm transition-colors">Về chúng tôi</a></li>
          <li><a href="/src/pages/du-an.astro" class="text-[#475569] hover:text-[#F97316] text-sm transition-colors">Dự án đã thực hiện</a></li>
          <li><a href="/src/pages/lien-he.astro" class="text-[#475569] hover:text-[#F97316] text-sm transition-colors">Liên hệ báo giá</a></li>
          <li><a href="/src/pages/bao-hanh.astro" class="text-[#475569] hover:text-[#F97316] text-sm transition-colors">Chính sách bảo hành</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-[#0F172A] font-black text-sm uppercase tracking-widest mb-6">Liên hệ trực tiếp</h3>
        <ul class="space-y-4">
          <li class="flex gap-3">
            <span class="text-[#F97316]">📍</span>
            <span class="text-[#475569] text-sm">TP. Thủ Đức & Quận 1, TP. Hồ Chí Minh</span>
          </li>
          <li class="flex gap-3">
            <span class="text-[#F97316]">📞</span>
            <a href="tel:0866077040" class="text-[#1B3A6B] font-black text-sm hover:text-[#F97316]">0866.077.040</a>
          </li>
          <li class="flex gap-3">
            <span class="text-[#F97316]">✉️</span>
            <span class="text-[#475569] text-sm">contact@idecal.vn</span>
          </li>
        </ul>
      </div>
    </div>

    <div class="pt-8 border-t border-[#E2E8F0] flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-[#475569] text-xs font-medium">
        © {currentYear} iDecal.vn - Thi công chuyên nghiệp. All rights reserved.
      </p>
      <div class="flex gap-6">
        <a href="#" class="text-[#475569] text-xs hover:text-[#F97316]">Bảo mật</a>
        <a href="#" class="text-[#475569] text-xs hover:text-[#F97316]">Điều khoản</a>
      </div>
    </div>
  </div>
</footer>
