---
const commitments = [
  {
    title: "Giao hàng hỏa tốc",
    desc: "Gửi hàng ngay trong ngày qua chành xe hoặc CPN",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>`
  },
  {
    title: "Thanh toán linh hoạt",
    desc: "Chuyển khoản hoặc COD khi nhận hàng toàn quốc",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>`
  },
  {
    title: "Đóng gói chuyên dụng",
    desc: "Ống nhựa cứng bảo vệ decal không gãy nếp",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><polyline points="3.27 6.96 12 12.01 20.73 6.96"/><line x1="12" y1="22.08" x2="12" y2="12"/></svg>`
  },
  {
    title: "Hỗ trợ file kỹ thuật",
    desc: "Kiểm tra và vẽ lại file vector miễn phí",
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`
  }
];
---

<section class="bg-white py-16 border-t border-gray-100">
  <div class="max-w-7xl mx-auto px-4">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      {commitments.map(item => (
        <div class="text-center group">
          <div class="w-12 h-12 mx-auto mb-4 text-primary transition-transform group-hover:scale-110" set:html={item.icon}></div>
          <h3 class="text-sm font-bold text-black uppercase mb-2 tracking-tight">{item.title}</h3>
          <p class="text-gray-500 text-xs leading-relaxed">{item.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<footer class="bg-[#F5F5F5] text-[#2D3436] pt-16 pb-8">
  <div class="max-w-7xl mx-auto px-4 grid grid-cols-1 md:grid-cols-4 gap-12">
    
    <div>
      <h2 class="text-2xl font-bold text-primary mb-2">catdecal.vn</h2>
      <div class="w-10 h-0.5 bg-primary mb-4"></div>
      <p class="text-gray-500 text-sm leading-relaxed">
        Xưởng gia công cắt decal chuyên nghiệp tại Bình Định. Đảm bảo độ chính xác tuyệt đối trên mọi chất liệu.
      </p>
    </div>

    <div>
      <h3 class="text-sm font-bold uppercase tracking-wider mb-2 text-black">Dịch vụ chính</h3>
      <div class="w-8 h-0.5 bg-primary mb-4"></div>
      <ul class="text-gray-600 text-sm space-y-3">
        <li><a href="/dich-vu/cat-decal-mau" class="hover:text-primary transition-colors">Cắt Decal màu quảng cáo</a></li>
        <li><a href="/dich-vu/cat-decal-mo" class="hover:text-primary transition-colors">Cắt Decal mờ vách kính</a></li>
        <li><a href="/dich-vu/cat-be-tem-nhan" class="hover:text-primary transition-colors">Bế tem nhãn sản phẩm</a></li>
        <li><a href="/dich-vu/cat-decal-phan-quang" class="hover:text-primary transition-colors">Cắt Decal phản quang</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-bold uppercase tracking-wider mb-2 text-black">Hỗ trợ khách hàng</h3>
      <div class="w-8 h-0.5 bg-primary mb-4"></div>
      <ul class="text-gray-600 text-sm space-y-3">
        <li><a href="/quy-trinh-dat-hang" class="hover:text-primary transition-colors">Quy trình đặt hàng</a></li>
        <li><a href="/giao-hang-thanh-toan" class="hover:text-primary transition-colors">Giao hàng & Thanh toán</a></li>
        <li><a href="#" class="hover:text-primary transition-colors">Hướng dẫn chuẩn bị file</a></li>
        <li><a href="#" class="hover:text-primary transition-colors">Chính sách bảo hành</a></li>
      </ul>
    </div>

    <div>
      <h3 class="text-sm font-bold uppercase tracking-wider mb-2 text-black">Thông tin liên hệ</h3>
      <div class="w-8 h-0.5 bg-primary mb-4"></div>
      <p class="text-primary font-bold text-xl mb-1">0862 208 108</p>
      <p class="text-gray-600 text-sm">Zalo/Hotline hỗ trợ 24/7</p>
      <p class="text-gray-500 text-sm mt-4">
        <span class="block font-medium text-black">Địa chỉ xưởng:</span>
        TP. Quy Nhơn, Tỉnh Bình Định
      </p>
    </div>

  </div>
  
  <div class="max-w-7xl mx-auto px-4 mt-16 pt-8 border-t border-gray-200 text-center">
    <p class="text-gray-400 text-xs">
      © 2026 catdecal.vn - Thiết kế bởi iDecal Ecosystem.
    </p>
  </div>
</footer>

<style>
  /* Triệt tiêu in nghiêng toàn bộ */
  h2, h3, p, a, span, li {
    font-style: normal !important;
  }
</style>
