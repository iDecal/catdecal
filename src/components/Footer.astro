<footer class="bg-[#f0f9ff] text-slate-600 pt-16 md:pt-24 pb-12 border-t border-slate-100">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-6 md:gap-12 lg:gap-20">
    
    <div class="footer-column mb-4 md:mb-0">
      <h2 class="text-3xl font-black text-slate-900 mb-6 tracking-tighter">catdecal<span class="text-secondary">.vn</span></h2>
      <p class="text-[15px] md:text-sm leading-7 mb-6 text-slate-400">
        Hệ sinh thái iDecal - Xưởng gia công cắt decal và interior film chuyên nghiệp tại Quy Nhơn.
      </p>
      
      <div class="flex gap-3 md:gap-4">
        {socials.map(social => (
          <a 
            href={social.url} 
            class="social-icon w-11 h-11 md:w-10 md:h-10 bg-white rounded-xl flex items-center justify-center transition-all shadow-sm border border-slate-50 p-2.5"
            style={`--brand-color: ${social.color}`}
            aria-label={social.name}
          >
            <div class="w-full h-full text-slate-400 icon-svg transition-colors" set:html={social.icon}></div>
          </a>
        ))}
      </div>
    </div>

    <div class="footer-accordion border-b border-slate-200/50 md:border-0">
      <button class="w-full flex justify-between items-center py-4 md:py-0 md:cursor-default accordion-btn">
        <h3 class="text-lg md:text-[11px] font-bold md:uppercase md:tracking-[0.2em] text-slate-900">Dịch vụ chính</h3>
        <span class="md:hidden text-2xl font-light text-primary">+</span>
      </button>
      <div class="footer-content hidden md:block mt-6 md:mt-8 pb-3 md:pb-0">
        <ul class="text-[16px] md:text-sm space-y-3 md:space-y-5">
          <li><a href="/dich-vu/cat-decal-mau" class="hover:text-secondary transition-colors py-1.5 block md:py-0">Cắt Decal quảng cáo</a></li>
          <li><a href="/dich-vu/cat-decal-mo" class="hover:text-secondary transition-colors py-1.5 block md:py-0">Cắt Decal mờ vách kính</a></li>
          <li><a href="/dich-vu/cat-be-tem-nhan" class="hover:text-secondary transition-colors py-1.5 block md:py-0">Bế tem nhãn sản phẩm</a></li>
          <li><a href="/dich-vu/cat-decal-phan-quang" class="hover:text-secondary transition-colors py-1.5 block md:py-0">Cắt Decal phản quang</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-accordion border-b border-slate-200/50 md:border-0">
      <button class="w-full flex justify-between items-center py-4 md:py-0 md:cursor-default accordion-btn">
        <h3 class="text-lg md:text-[11px] font-bold md:uppercase md:tracking-[0.2em] text-slate-900">Thông tin hỗ trợ</h3>
        <span class="md:hidden text-2xl font-light text-primary">+</span>
      </button>
      <div class="footer-content hidden md:block mt-6 md:mt-8 pb-3 md:pb-0">
        <ul class="text-[16px] md:text-sm space-y-3 md:space-y-5">
          <li><a href="/blog" class="hover:text-secondary transition-colors py-1.5 block md:py-0">Blog kiến thức</a></li>
          <li><a href="/quy-trinh-dat-hang" class="hover:text-secondary transition-colors py-1.5 block md:py-0">Quy trình đặt hàng</a></li>
          <li><a href="/giao-hang-thanh-toan" class="hover:text-secondary transition-colors py-1.5 block md:py-0">Giao hàng & Thanh toán</a></li>
          <li><a href="#" class="hover:text-secondary transition-colors py-1.5 block md:py-0">Chính sách dịch vụ</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-accordion md:border-0">
      <button class="w-full flex justify-between items-center py-4 md:py-0 md:cursor-default accordion-btn">
        <h3 class="text-lg md:text-[11px] font-bold md:uppercase md:tracking-[0.2em] text-slate-900">Liên hệ</h3>
        <span class="md:hidden text-2xl font-light text-primary">+</span>
      </button>
      <div class="footer-content hidden md:block mt-6 md:mt-8 pb-6 md:pb-0">
        <p class="text-secondary font-black text-3xl md:text-2xl mb-1 md:mb-2 tracking-tight">0862 208 108</p>
        <p class="text-slate-400 text-[13px] md:text-[11px] tracking-wide mb-5">Zalo hỗ trợ 24/7</p>
        <div class="text-[15px] md:text-sm text-slate-500 leading-relaxed">
          <p class="font-bold text-slate-900 mb-0.5">Xưởng sản xuất:</p>
          <p>TP. Quy Nhơn, Tỉnh Bình Định</p>
        </div>
      </div>
    </div>

  </div>
  
  <div class="max-w-7xl mx-auto px-6 mt-12 md:mt-24 pt-8 border-t border-slate-200/40 text-center">
    <p class="text-slate-300 text-[10px] font-medium tracking-[0.3em] uppercase">
      © 2026 CATDECAL.VN — iDecal Ecosystem
    </p>
  </div>
</footer>

<style>
  a { text-decoration: none; }

  /* Brand Color Interaction */
  .social-icon:hover {
    background-color: var(--brand-color);
    border-color: var(--brand-color);
    transform: translateY(-3px);
  }
  .social-icon:hover .icon-svg {
    color: white;
  }

  @media (max-width: 767px) {
    .footer-accordion h3 {
      text-transform: none;
      letter-spacing: normal;
    }
  }
</style>

<script>
  // Script giữ nguyên như bản trước để xử lý accordion mượt mà
  function setupFooter() {
    const accordions = document.querySelectorAll('.footer-accordion');
    accordions.forEach(item => {
      const btn = item.querySelector('.accordion-btn');
      const content = item.querySelector('.footer-content');
      const span = item.querySelector('span');

      btn?.addEventListener('click', () => {
        if (window.innerWidth < 768) {
          const isOpen = !content?.classList.contains('hidden');
          document.querySelectorAll('.footer-content').forEach(c => c.classList.add('hidden'));
          document.querySelectorAll('.footer-accordion span').forEach(s => s.textContent = '+');
          if (!isOpen) {
            content?.classList.remove('hidden');
            if (span) span.textContent = '−';
          }
        }
      });
    });
  }
  setupFooter();
  document.addEventListener('astro:after-swap', setupFooter);
</script>
