---
const services = [
  { title: "Cắt Chữ & Logo", icon: "🏢", desc: "Dán kính văn phòng, cửa hiệu chuyên nghiệp." },
  { title: "Tem Nhãn & Sticker", icon: "🏷️", desc: "Giải pháp cho Shop Online và quán Cafe." },
  { title: "Decal Phản Quang", icon: "✨", desc: "Biển báo công trình và cá nhân hóa xe." },
  { title: "Trang Trí Nội Thất", icon: "🏠", desc: "Làm mới không gian sống với chi phí rẻ." },
  { title: "Cắt Gia Công", icon: "⚙️", desc: "Cắt decal lẻ lấy ngay, hỗ trợ file vector." }
];
---

<div class="services-grid">
  {services.map(s => (
    <div class="card">
      <span class="icon">{s.icon}</span>
      <h3>{s.title}</h3>
      <p>{s.desc}</p>
      <a href={`/services/${s.title.toLowerCase()}`}>Xem chi tiết</a>
    </div>
  ))}
</div>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 20px;
    padding: 40px 0;
  }
  .card {
    padding: 20px;
    border: 1px solid #eee;
    border-radius: 12px;
    transition: transform 0.3s;
    background: var(--bg-card, #fff); /* Sử dụng biến CSS của bạn */
  }
  .card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.05);
  }
  h3 { color: var(--primary-color); } /* Tự động lấy màu của bạn */
</style>
