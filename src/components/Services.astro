---

<section class="services-section">
  <div class="container">
    <div class="section-header">
      <span class="badge">Dịch vụ thế mạnh</span>
      <h2>Giải pháp cắt Decal chuyên nghiệp</h2>
      <p>Chúng tôi tập trung vào độ chính xác, tốc độ và chất lượng vật liệu hàng đầu.</p>
    </div>

    <div class="services-grid">
      {services.map((s, index) => (
        <div class={`service-card ${index === 0 ? 'featured' : ''}`}>
          <div class="card-content">
            <span class="subtitle">{s.subtitle}</span>
            <h3>{s.title}</h3>
            <p>{s.desc}</p>
            <div class="tags">
              {s.tags.map(tag => <span>{tag}</span>)}
            </div>
            <a href={`/dich-vu/${s.id}`} class="learn-more">
              Khám phá thêm 
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14m-7-7 7 7-7 7"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>



  /* Mobile */
  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
    h2 { font-size: 2rem; }
  }
</style>
