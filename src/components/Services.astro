---
import { brand } from '../config/brand'; // Đảm bảo đường dẫn này đúng với file brand của bạn

const services = [
  {
    title: "Cắt Decal Chữ & Logo",
    subtitle: "Văn phòng & Cửa hiệu",
    desc: "Chuyên dán kính mờ vách ngăn, cắt chữ tên công ty và slogan truyền cảm hứng.",
    tags: ["Dán kính mờ", "Slogan", "Biển phòng ban"],
    featured: true 
  },
  {
    title: "Tem Nhãn & Sticker",
    subtitle: "Shop Online & F&B",
    desc: "Cắt bế tem nhãn sản phẩm, sticker niêm phong cho chai lọ, hộp bánh, mỹ phẩm.",
    tags: ["Tem bế chuẩn", "Sticker nhựa", "Nhãn decal"],
  },
  {
    title: "Decal Phản Quang",
    subtitle: "Kỹ thuật & An toàn",
    desc: "Vật liệu phản quang cao cấp cho biển báo, tem xe hội nhóm và trang phục bảo hộ.",
    tags: ["Phản quang 3M", "Biển báo", "Tem xe"],
  },
  {
    title: "Trang Trí Nội Thất",
    subtitle: "Cá nhân & Decor",
    desc: "Cắt decal dán tường, skin máy tính hoặc film vân gỗ làm mới nội thất cũ.",
    tags: ["Dán tường", "Skin Laptop", "Vân gỗ/đá"],
  },
  {
    title: "Cắt Gia Công Lấy Ngay",
    subtitle: "Đối tác B2B & Thợ",
    desc: "Nhận cắt theo file vector gửi qua Zalo, cắt khuôn sơn stencil, decal khổ lớn.",
    tags: ["Cắt lẻ", "Khổ 1m2", "File Vector"],
  }
];
---

<section class="services-area">
  <div class="container">
    <div class="header-group">
      <span class="accent-label">Dịch vụ trọng tâm</span>
      <h2>Phân khúc dịch vụ chuyên biệt</h2>
      <p>Đáp ứng mọi nhu cầu từ cắt lẻ cá nhân đến công trình văn phòng quy mô lớn.</p>
    </div>

    <div class="bento-grid">
      {services.map(s => (
        <div class={`service-card ${s.featured ? 'is-featured' : ''}`}>
          <div class="card-inner">
            <header>
              <span class="sub-title">{s.subtitle}</span>
              <h3>{s.title}</h3>
            </header>
            
            <p>{s.desc}</p>
            
            <div class="tag-cloud">
              {s.tags.map(tag => <span>{tag}</span>)}
            </div>

            <a href={`/services/`} class="cta-link">
              Tìm hiểu thêm
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .services-area {
    padding: 100px 0;
    background-color: var(--background); /* #ffffff */
  }

  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .header-group {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 60px;
  }

  .accent-label {
    color: var(--accent); /* #F97316 */
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.8rem;
    letter-spacing: 0.1em;
  }

  h2 {
    color: var(--primary); /* #1B3A6B */
    font-family: var(--display-font); /* Inter */
    font-size: 2.5rem;
    font-weight: 800;
    margin: 1rem 0;
  }

  .bento-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 24px;
  }

  .service-card {
    background: var(--surface); /* #F8FAFC */
    border: 1px solid var(--border); /* #E2E8F0 */
    border-radius: var(--radius-lg); /* 1rem */
    padding: 2.5rem;
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
  }

  .service-card:hover {
    border-color: var(--primary-light);
    transform: translateY(-8px);
    box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.05);
  }

  .is-featured {
    background: var(--primary); /* #1B3A6B */
    color: var(--primary-fg); /* #ffffff */
  }

  .is-featured h3, .is-featured p, .is-featured .sub-title {
    color: #ffffff;
  }

  .is-featured .sub-title {
    color: var(--accent);
  }

  .sub-title {
    color: var(--primary-light);
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    display: block;
  }

  h3 {
    font-family: var(--display-font);
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
  }

  p {
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.6;
    margin-bottom: 2rem;
  }

  .tag-cloud {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 2.5rem;
  }

  .tag-cloud span {
    background: var(--background);
    border: 1px solid var(--border);
    padding: 4px 12px;
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    color: var(--text);
  }

  .is-featured .tag-cloud span {
    background: rgba(255,255,255,0.1);
    border-color: rgba(255,255,255,0.2);
    color: #fff;
  }

  .cta-link {
    margin-top: auto;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--primary-light);
    text-decoration: none;
    font-weight: 700;
    font-size: 0.95rem;
    transition: gap 0.2s;
  }

  .cta-link:hover {
    gap: 14px;
  }

  .is-featured .cta-link {
    color: var(--accent);
  }

  @media (max-width: 768px) {
    h2 { font-size: 1.8rem; }
    .service-card { padding: 1.5rem; }
  }
</style>
