---
const faqs = [
  {
    q: "Làm thế nào để tôi đặt hàng từ xa?",
    a: "Quy trình rất đơn giản: Bạn gửi file thiết kế qua Zalo hoặc Email. Chúng tôi kiểm tra kỹ thuật, báo giá và thực hiện gia công ngay sau khi chốt đơn. Sản phẩm sẽ được gửi đến tận nơi qua các đơn vị chuyển phát nhanh hoặc nhà xe."
  },
  {
    q: "Xưởng hỗ trợ những định dạng file thiết kế nào?",
    a: "Để đường cắt đạt độ chính xác cao nhất, chúng tôi khuyến khích khách hàng gửi file định dạng Vector như .AI, .Corel (CDR), .PDF hoặc .EPS. Nếu bạn chỉ có ảnh chụp, chúng tôi hỗ trợ vẽ lại file vector chuẩn máy cắt."
  },
  {
    q: "Quy chuẩn đóng gói hàng gửi tỉnh như thế nào?",
    a: "Chúng tôi sử dụng ống nhựa PVC hoặc ống giấy cứng chịu lực để cuộn decal. Quy trình này giúp decal không bị gãy nếp, bong tróc đường cắt và đảm bảo an toàn tuyệt đối khi vận chuyển đi xa."
  },
  {
    q: "Thời gian gia công và giao hàng mất bao lâu?",
    a: "Thời gian gia công thường trong vòng 24h. Thời gian nhận hàng tùy thuộc vào đơn vị vận chuyển: Chuyển phát nhanh từ 2-4 ngày, gửi chành xe có thể nhận ngay trong ngày hoặc hôm sau tùy khu vực."
  },
  {
    q: "Chính sách bảo hành sản phẩm ra sao?",
    a: "Chúng tôi cam kết lỗi 1 đổi 1 nếu sản phẩm không đúng mẫu mã, sai kích thước file thiết kế đã chốt hoặc hư hỏng nặng do lỗi vận chuyển khi khách hàng có video mở hàng."
  }
];
---

<section class="py-20 bg-[#F5F5F5]">
  <div class="max-w-6xl mx-auto px-4">
    <div class="text-center mb-16">
      <h2 class="text-3xl text-black mb-3 font-bold tracking-tighter">Câu hỏi thường gặp</h2>
      <div class="w-16 h-1.5 bg-primary mx-auto mb-4"></div>
      <p class="text-gray-400 text-xs font-bold uppercase tracking-widest">Hỗ trợ giải đáp thắc mắc về gia công và vận chuyển toàn quốc</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="faq-container">
      {faqs.map((faq) => (
        <div class="faq-item bg-white rounded-2xl border border-divider overflow-hidden h-fit transition-all duration-300">
          <button class="faq-question w-full p-6 text-left flex justify-between items-center gap-4 group">
            <h3 class="text-base md:text-lg text-black font-bold flex items-start gap-3">
              <span class="text-primary">Q:</span>
              {faq.q}
            </h3>
            <span class="faq-icon text-gray-300 transition-transform duration-300 group-hover:text-black">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path></svg>
            </span>
          </button>
          
          <div class="faq-answer max-h-0 overflow-hidden transition-all duration-300 ease-in-out bg-gray-50/50">
            <div class="p-6 pt-0 pl-14 border-t border-gray-50 mt-4">
              <p class="text-gray-600 text-sm leading-relaxed py-4">
                <span class="font-bold text-gray-400 mr-2 uppercase text-[10px]">Trả lời:</span>
                {faq.a}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  function initFAQ() {
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
      const button = item.querySelector('.faq-question');
      const answer = item.querySelector('.faq-answer');
      const icon = item.querySelector('.faq-icon');

      button?.addEventListener('click', () => {
        const isOpen = answer?.style.maxHeight && answer.style.maxHeight !== '0px';

        // Đóng các cái khác (nếu muốn dạng chỉ mở 1 cái 1 lúc)
        // document.querySelectorAll('.faq-answer').forEach(el => el.style.maxHeight = '0px');
        // document.querySelectorAll('.faq-icon').forEach(el => el.style.transform = 'rotate(0deg)');

        if (isOpen) {
          (answer as HTMLElement).style.maxHeight = '0px';
          (icon as HTMLElement).style.transform = 'rotate(0deg)';
          item.classList.remove('border-black');
        } else {
          (answer as HTMLElement).style.maxHeight = answer?.scrollHeight + 'px';
          (icon as HTMLElement).style.transform = 'rotate(180deg)';
          item.classList.add('border-black');
        }
      });
    });
  }

  // Chạy khi trang load
  initFAQ();
  // Chạy lại khi chuyển trang trong Astro (nếu dùng View Transitions)
  document.addEventListener('astro:page-load', initFAQ);
</script>

<style>
  /* Loại bỏ in nghiêng cho toàn bộ section */
  section {
    font-style: normal !important;
  }
  
  .faq-item.border-black {
    box-shadow: 0 10px 30px -10px rgba(0,0,0,0.1);
  }
</style>
