---
const services = [
  { title: "Cắt Chữ & Logo", icon: "📐", desc: "Cắt theo file vector cho văn phòng, cửa hàng." },
  { title: "Bế Tem Nhãn", icon: "🏷️", desc: "Cắt bế theo hình thù yêu cầu cho sticker, nhãn chai." },
  { title: "Cắt Gia Công B2B", icon: "🏭", desc: "Hỗ trợ thợ quảng cáo gia công khối lượng lớn." }
];

const materials = [
  { name: "Decal Mờ", img: "https://images.unsplash.com/photo-1626708722760-466033488825?q=80&w=400", desc: "Dán kính vách ngăn, tạo không gian riêng tư." },
  { name: "Decal Phản Quang", img: "https://images.unsplash.com/photo-1616432043562-3671ea2e5241?q=80&w=400", desc: "Vật liệu 3M, biển báo giao thông, tem xe." },
  { name: "Decal Màu/Trong", img: "https://images.unsplash.com/photo-1589987607627-616cac5c2c5a?q=80&w=400", desc: "Trang trí quảng cáo, dán tường, dán kính." },
  { name: "Decal Nội Thất", img: "https://images.unsplash.com/photo-1615873968403-89e068629275?q=80&w=400", desc: "Giả gỗ, giả đá, phim dán nội thất cao cấp." }
];
---

<section class="py-24 bg-slate-50">
  <div class="container mx-auto px-4">
    
    <div class="mb-20">
      <div class="flex items-center gap-4 mb-12">
        <h2 class="text-2xl font-heading font-black italic text-primary uppercase">Dịch vụ gia công</h2>
        <div class="h-px bg-slate-200 flex-grow"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {services.map(s => (
          <div class="bg-white p-8 rounded-2xl border border-slate-100 shadow-sm hover:border-secondary transition-all group">
            <div class="text-4xl mb-4 group-hover:scale-110 transition-transform inline-block">{s.icon}</div>
            <h3 class="text-lg font-bold text-primary mb-2 uppercase italic">{s.title}</h3>
            <p class="text-xs text-copy-muted leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <div class="flex items-center gap-4 mb-12">
        <h2 class="text-2xl font-heading font-black italic text-primary uppercase">Kho vật liệu sẵn có</h2>
        <div class="h-px bg-slate-200 flex-grow"></div>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
        {materials.map(m => (
          <div class="group cursor-pointer">
            <div class="relative aspect-square rounded-2xl overflow-hidden mb-4">
              <img src={m.img} class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700" alt={m.name} />
              <div class="absolute inset-0 bg-primary/20 group-hover:bg-transparent transition-colors"></div>
            </div>
            <h3 class="font-bold text-primary text-sm uppercase italic mb-1">{m.name}</h3>
            <p class="text-[11px] text-copy-muted leading-tight">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>
