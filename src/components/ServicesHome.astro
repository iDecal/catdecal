---
const services = [
  { 
    title: "Cắt Chữ & Logo", 
    img: "https://images.unsplash.com/photo-1621252179027-94459d278660?q=80&w=400", 
    desc: "Cắt theo file vector cho văn phòng, cửa hàng." 
  },
  { 
    title: "Bế Tem Nhãn", 
    img: "https://images.unsplash.com/photo-1601933513793-120090886c95?q=80&w=400", 
    desc: "Cắt bế theo hình thù yêu cầu cho sticker, nhãn chai." 
  },
  { 
    title: "Cắt Gia Công B2B", 
    img: "https://images.unsplash.com/photo-1581091226825-a6a2a5aee158?q=80&w=400", 
    desc: "Hỗ trợ thợ quảng cáo gia công khối lượng lớn." 
  }
];

const materials = [
  { 
    name: "Decal Mờ", 
    img: "https://images.unsplash.com/photo-1626708722760-466033488825?q=80&w=400", 
    desc: "Dán kính vách ngăn, riêng tư." 
  },
  { 
    name: "Decal Phản Quang", 
    img: "https://images.unsplash.com/photo-1616432043562-3671ea2e5241?q=80&w=400", 
    desc: "Vật liệu 3M, biển báo, tem xe." 
  },
  { 
    name: "Decal Màu/Trong", 
    img: "https://images.unsplash.com/photo-1589987607627-616cac5c2c5a?q=80&w=400", 
    desc: "Trang trí, dán tường, dán kính." 
  },
  { 
    name: "Decal Nội Thất", 
    img: "https://images.unsplash.com/photo-1615873968403-89e068629275?q=80&w=400", 
    desc: "Giả gỗ, giả đá, cao cấp." 
  }
];
---

<section class="py-16 md:py-24 bg-slate-50">
  <div class="container mx-auto px-4">
    
    <div class="mb-20">
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-xl md:text-2xl font-black italic text-primary uppercase whitespace-nowrap">Dịch vụ gia công</h2>
        <div class="h-px bg-slate-200 flex-grow"></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {services.map(s => (
          <div class="group cursor-pointer">
            <div class="relative aspect-video rounded-2xl overflow-hidden mb-5 shadow-sm">
              <img 
                src={s.img} 
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" 
                alt={s.title} 
              />
              <div class="absolute inset-0 bg-black/10 group-hover:bg-transparent transition-colors"></div>
            </div>
            <h3 class="text-lg font-bold text-black mb-2 uppercase italic leading-none">{s.title}</h3>
            <p class="text-xs text-gray-500 leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>

    <div>
      <div class="flex items-center gap-4 mb-10">
        <h2 class="text-xl md:text-2xl font-black italic text-primary uppercase whitespace-nowrap">Kho vật liệu sẵn có</h2>
        <div class="h-px bg-slate-200 flex-grow"></div>
      </div>

      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 md:gap-8">
        {materials.map(m => (
          <div class="group cursor-pointer">
            <div class="relative aspect-square rounded-2xl overflow-hidden mb-4 shadow-sm">
              <img 
                src={m.img} 
                class="w-full h-full object-cover group-hover:scale-110 transition-all duration-700" 
                alt={m.name} 
              />
              <div class="absolute inset-0 bg-primary/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
            </div>
            <h3 class="font-bold text-black text-sm uppercase italic mb-1 leading-none">{m.name}</h3>
            <p class="text-[11px] text-gray-400 leading-tight">{m.desc}</p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>

<style>
  /* Triệt tiêu in nghiêng toàn bộ */
  h2, h3, p {
    font-style: normal !important;
  }
  /* Giữ italic cho phong cách iDecal */
  .italic {
    font-style: italic !important;
  }
</style>
