<div 
  id="mobile-menu" 
  class="fixed inset-0 bg-white z-[90] translate-x-full transition-transform duration-500 lg:hidden flex flex-col h-[100dvh]"
>
  <div class="flex-1 overflow-y-auto pt-24 pb-32 px-6">
    <div class="flex flex-col space-y-1">
      {menuData.map(item => (
        <div class="border-b border-slate-50 py-4">
          <a href={item.href} class="text-xl font-bold text-slate-800 uppercase flex justify-between items-center">
            {item.name}
            {item.submenu && <span class="text-secondary text-[10px]">▼</span>}
          </a>
          
          {item.submenu && (
            <div class="grid grid-cols-1 gap-4 mt-5 ml-4 border-l border-slate-100 pl-4">
              {item.submenu.map(sub => (
                <a href={sub.href} class="text-xs font-bold text-slate-400 uppercase tracking-widest py-1 active:text-secondary">
                  {sub.name}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </div>
  </div>

  <div class="p-6 border-t border-slate-50 bg-white">
    <a href="https://zalo.me/your-number" class="bg-secondary/10 text-secondary w-full py-4 rounded-xl font-bold uppercase tracking-widest block text-center">
      Liên hệ báo giá
    </a>
  </div>
</div>
