---
// Header.astro
---

<header class="bg-white border-b border-divider sticky top-0 z-50 shadow-sm font-heading">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-20 items-center">
      
      <div class="flex items-center">
        <a href="/" class="flex items-center">
          <img 
            src="/images/logo-catdecal.vn.jpg" 
            alt="catdecal.vn" 
            class="h-12 w-auto object-contain"
          />
        </a>
      </div>

      <nav class="hidden md:flex space-x-8 items-center h-full">
        <a href="/" class="text-copy hover:text-primary font-medium transition-colors">Trang chủ</a>
        
        <div class="relative group h-full flex items-center">
          <a href="/dich-vu" class="text-copy group-hover:text-primary font-medium flex items-center gap-1 transition-colors h-full">
            Dịch vụ cắt 
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
            </svg>
          </a>

          <div class="absolute top-full left-0 w-64 bg-white shadow-xl rounded-b-xl border border-divider opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all z-50 py-2 border-t-0">
            <a href="/dich-vu/cat-decal-mau" class="block px-4 py-3 hover:bg-primary/5 hover:text-primary transition-colors text-sm">Cắt Decal màu (Quảng cáo)</a>
            <a href="/dich-vu/cat-decal-mo" class="block px-4 py-3 hover:bg-primary/5 hover:text-primary transition-colors text-sm">Cắt Decal mờ (Dán kính)</a>
            <a href="/dich-vu/cat-be-tem-nhan" class="block px-4 py-3 hover:bg-primary/5 hover:text-primary transition-colors text-sm">Cắt bế Tem nhãn (Sau in)</a>
            <a href="/dich-vu/cat-decal-phan-quang" class="block px-4 py-3 hover:bg-primary/5 hover:text-primary transition-colors text-sm">Cắt Decal phản quang</a>
            <a href="/dich-vu/cat-decal-chuyen-nhiet" class="block px-4 py-3 hover:bg-primary/5 hover:text-primary transition-colors text-sm">Cắt Decal chuyển nhiệt (Ép áo)</a>
          </div>
        </div>

        <a href="/bao-gia" class="text-copy hover:text-primary font-medium transition-colors">Báo giá nhanh</a>
        <a href="/giao-hang-thanh-toan" class="text-copy hover:text-primary font-medium transition-colors">Giao hàng</a>
        <a href="/thu-vien-mau" class="text-copy hover:text-primary font-medium transition-colors">Thư viện mẫu</a>
      </nav>

      <div class="hidden md:block">
        <a href="https://zalo.me/0862208108" target="_blank" class="bg-primary text-white px-6 py-2.5 rounded-lg font-bold hover:bg-red-600 transition-all shadow-md uppercase text-sm">
          Gửi file ngay
        </a>
      </div>

      <div class="md:hidden">
        <button id="menu-btn" class="p-2 text-black focus:outline-none" aria-label="Toggle Menu">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path id="menu-icon" d="M4 6h16M4 12h16m-7 6h7" stroke-width="2" stroke-linecap="round"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-divider shadow-inner">
    <div class="px-4 py-6 space-y-4">
      <a href="/" class="block text-lg font-medium border-b border-gray-50 pb-2">Trang chủ</a>
      <a href="/dich-vu" class="block text-lg font-medium border-b border-gray-50 pb-2">Dịch vụ cắt</a>
      <a href="/bao-gia" class="block text-lg font-medium border-b border-gray-50 pb-2">Báo giá nhanh</a>
      <a href="/giao-hang-thanh-toan" class="block text-lg font-medium border-b border-gray-50 pb-2">Giao hàng</a>
      <a href="https://zalo.me/0862208108" class="w-full block text-center bg-primary text-white py-4 rounded-lg font-bold shadow-lg">GỬI FILE QUA ZALO</a>
    </div>
  </div>
</header>

<script>
  function setupMenu() {
    const btn = document.getElementById('menu-btn');
    const menu = document.getElementById('mobile-menu');

    if (btn && menu) {
      // Xóa bỏ listener cũ để tránh trùng lặp khi Astro swap trang
      btn.replaceWith(btn.cloneNode(true));
      const newBtn = document.getElementById('menu-btn');
      
      newBtn?.addEventListener('click', () => {
        menu.classList.toggle('hidden');
      });
    }
  }

  // Chạy khi lần đầu load trang
  setupMenu();

  // Chạy lại khi chuyển trang (View Transitions)
  document.addEventListener('astro:after-swap', setupMenu);
</script>

<style>
  /* Đảm bảo ảnh logo không bị méo */
  img {
    max-height: 50px;
    width: auto;
  }
</style>
