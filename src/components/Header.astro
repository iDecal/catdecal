---
// src/components/Header.astro
const navLinks = [
  { name: 'Trang chủ', href: '/' },
  { name: 'Dịch vụ & Vật liệu', href: '#', 
    submenu: [
      { name: 'Decal Mờ (Frosted)', href: '/vat-lieu/decal-mo' },
      { name: 'Decal Trong (Clear)', href: '/vat-lieu/decal-trong' },
      { name: 'Decal Màu (PVC)', href: '/vat-lieu/decal-pvc-mau' },
      { name: 'Decal Phản quang', href: '/vat-lieu/decal-phan-quang' },
      { name: 'Sticker & Tem bế', href: '/dich-vu/sticker-tem-be' }
    ]
  },
  { name: 'Thư viện mẫu', href: '/thu-vien' },
  { name: 'Blog', href: '/blog', 
  submenu: [
    { name: 'Kỹ thuật dán decal', href: '/blog/ky-thuat-dan' },
    { name: 'Ứng dụng sáng tạo', href: '/blog/ung-dung' },
    { name: 'Review vật liệu', href: '/blog/vat-lieu' },
    { name: 'Hướng dẫn thiết kế', href: '/blog/thiet-ke' }
  ]
},
  { name: 'Hướng dẫn gửi file', href: '/huong-dan' },
];
---

<header class="fixed w-full z-50 bg-white/95 backdrop-blur-md border-b border-divider">
  <div class="max-w-7xl mx-auto px-4 h-16 md:h-20 flex justify-between items-center">
    
   <a href="/" class="flex items-center group">
      <img 
        src="/images/logo-catdecal.vn.jpg" 
        alt="Xưởng Cắt Decal Chuyên Nghiệp - catdecal.vn" 
        class="h-10 md:h-12 w-auto object-contain transition-transform group-hover:scale-105"
      />
    </a>

    <nav class="hidden lg:flex space-x-7 items-center">
      {navLinks.map((link) => (
        <div class="relative group">
          <a href={link.href} class="text-[15px] font-medium text-copy hover:text-primary transition-colors flex items-center gap-1.5 py-2">
            {link.name}
            {link.submenu && (
              <svg class="w-4 h-4 opacity-40 group-hover:rotate-180 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M19 9l-7 7-7-7" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            )}
          </a>
          
          {link.submenu && (
            <div class="absolute left-0 mt-1 w-60 bg-white border border-divider rounded-xl shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 py-2 translate-y-2 group-hover:translate-y-0">
              {link.submenu.map((sub) => (
                <a href={sub.href} class="block px-5 py-3 text-sm text-copy hover:bg-surface hover:text-primary transition-colors font-medium">
                  {sub.name}
                </a>
              ))}
            </div>
          )}
        </div>
      ))}
    </nav>

    <div class="hidden lg:block">
      <a href="/bao-gia" class="px-6 py-2.5 rounded-lg text-sm font-bold text-white bg-primary hover:bg-primary-dark transition-all shadow-sm">
        Gửi file ngay
      </a>
    </div>

    <button id="menu-btn" class="lg:hidden z-50 p-2 text-copy outline-none" aria-label="Toggle Menu">
      <svg id="menu-icon" class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path id="path-top" d="M4 6h16" stroke-width="2.5" stroke-linecap="round"></path>
        <path id="path-mid" d="M4 12h16" stroke-width="2.5" stroke-linecap="round"></path>
        <path id="path-bot" d="M4 18h16" stroke-width="2.5" stroke-linecap="round"></path>
      </svg>
    </button>

    <div id="mobile-menu" class="fixed inset-0 bg-white translate-x-full transition-transform duration-300 lg:hidden flex flex-col pt-24 px-6 overflow-y-auto">
      <div class="flex flex-col space-y-6">
        {navLinks.map((link) => (
          <div class="flex flex-col border-b border-divider pb-4 last:border-0">
            <a href={link.href} class="text-xl font-bold text-copy flex items-center justify-between">
              {link.name}
            </a>
            {link.submenu && (
              <div class="grid grid-cols-1 gap-4 mt-4 pl-4 border-l-2 border-primary/20">
                {link.submenu.map((sub) => (
                  <a href={sub.href} class="text-base text-copy-light hover:text-primary active:text-primary">
                    {sub.name}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>

      <div class="mt-auto pb-10 pt-10">
        <a href="/bao-gia" class="block w-full py-4 rounded-xl text-center text-lg font-bold text-white bg-primary active:scale-95 transition-transform uppercase tracking-wide">
          Gửi file báo giá
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const pathTop = document.getElementById('path-top');
  const pathMid = document.getElementById('path-mid');
  const pathBot = document.getElementById('path-bot');
  let isOpen = false;

  menuBtn?.addEventListener('click', () => {
    isOpen = !isOpen;
    mobileMenu?.classList.toggle('translate-x-full', !isOpen);
    
    if (isOpen) {
      pathTop?.setAttribute('d', 'M6 18L18 6');
      pathMid?.setAttribute('opacity', '0');
      pathBot?.setAttribute('d', 'M6 6l12 12');
      document.body.style.overflow = 'hidden';
    } else {
      pathTop?.setAttribute('d', 'M4 6h16');
      pathMid?.setAttribute('opacity', '1');
      pathBot?.setAttribute('d', 'M4 18h16');
      document.body.style.overflow = '';
    }
  });
</script>

<style>
  #mobile-menu {
    height: 100dvh;
  }
</style>
