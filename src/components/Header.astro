---
// src/components/Header.astro
---

<header class="bg-surface border-b border-divider sticky top-0 z-50">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between h-20 items-center">
      
      <div class="flex-shrink-0 flex items-center">
        <a href="/" class="text-2xl font-heading font-bold text-primary tracking-tight">
          catdecal<span class="text-secondary">.vn</span>
        </a>
      </div>

      <nav class="hidden md:flex space-x-6 items-center">
        <a href="/" class="text-copy hover:text-primary font-medium transition-colors">Trang chủ</a>
        
        <div class="relative group py-4">
          <button class="text-copy group-hover:text-primary font-medium flex items-center gap-1 transition-colors">
            Dịch vụ cắt 
            <svg class="w-4 h-4 transition-transform group-hover:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7"></path></svg>
          </button>
          
          <div class="absolute hidden group-hover:block w-64 bg-surface border border-divider mt-0 rounded-custom shadow-soft overflow-hidden">
            <a href="/cat-decal-mau" class="block px-4 py-3 text-sm text-copy hover:bg-background hover:text-primary border-b border-divider/50">Cắt Decal màu (Quảng cáo)</a>
            <a href="/cat-decal-mo" class="block px-4 py-3 text-sm text-copy hover:bg-background hover:text-primary border-b border-divider/50">Cắt Decal mờ (Dán kính)</a>
            <a href="/be-tem-nhan" class="block px-4 py-3 text-sm text-copy hover:bg-background hover:text-primary border-b border-divider/50">Cắt bế Tem nhãn (Sau in)</a>
            <a href="/cat-phan-quang" class="block px-4 py-3 text-sm text-copy hover:bg-background hover:text-primary border-b border-divider/50">Cắt Decal Phản quang/Dạ quang</a>
            <a href="/cat-chuyen-nhiet" class="block px-4 py-3 text-sm text-copy hover:bg-background hover:text-primary">Cắt Decal Chuyển nhiệt (In áo)</a>
          </div>
        </div>

        <a href="/bao-gia" class="text-copy hover:text-primary font-medium transition-colors">Bảng tính giá</a>
        <a href="/mau-thuc-te" class="text-copy hover:text-primary font-medium transition-colors">Mẫu thực tế</a>
      </nav>

      <div class="hidden md:block">
        <a href="https://zalo.me/yourid" target="_blank" class="bg-primary text-white px-6 py-2.5 rounded-custom font-bold hover:bg-primary-dark shadow-md hover:shadow-lg transition-all transform hover:-translate-y-0.5">
          GỬI FILE BÁO GIÁ
        </a>
      </div>

      <div class="md:hidden">
        <button id="menu-btn" class="p-2 text-secondary focus:outline-none" aria-label="Menu">
          <svg id="menu-icon" class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7"></path>
          </svg>
        </button>
      </div>
    </div>
  </div>

  <div id="mobile-menu" class="hidden md:hidden bg-surface border-t border-divider animate-fade-in-down">
    <div class="px-4 pt-2 pb-6 space-y-1">
      <a href="/" class="block px-3 py-3 text-base font-medium text-copy border-b border-divider/50">Trang chủ</a>
      <div class="py-2 pl-3">
        <p class="text-xs font-bold text-copy-muted uppercase tracking-widest mb-2">Dịch vụ cắt vật liệu</p>
        <div class="grid grid-cols-1 gap-1">
          <a href="/cat-decal-mau" class="py-2 text-copy hover:text-primary">• Cắt Decal màu</a>
          <a href="/cat-decal-mo" class="py-2 text-copy hover:text-primary">• Cắt Decal mờ</a>
          <a href="/be-tem-nhan" class="py-2 text-copy hover:text-primary">• Bế Tem nhãn</a>
          <a href="/cat-phan-quang" class="py-2 text-copy hover:text-primary">• Decal Phản quang</a>
        </div>
      </div>
      <a href="/bao-gia" class="block px-3 py-3 text-base font-medium text-copy border-b border-divider/50">Bảng tính giá</a>
      <div class="mt-4 px-3">
        <a href="https://zalo.me/yourid" class="w-full flex justify-center items-center bg-primary text-white py-3 rounded-custom font-bold">
          GỬI FILE QUA ZALO
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  import { setupMenu } from '../scripts/menu.js';
  setupMenu();
</script>

<style>
  .animate-fade-in-down {
    animation: fadeInDown 0.3s ease-out forwards;
  }
  @keyframes fadeInDown {
    from { opacity: 0; transform: translateY(-10px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
