---
// src/pages/thu-vien.astro
const categories = ["Tất cả", "Chữ dán kính", "Sticker", "Hoa văn trang trí", "Logo Shop"];
const galleryItems = [
  { title: "Mẫu chữ Opening Hours", category: "Chữ dán kính", img: "/gallery/hours.jpg" },
  { title: "Hoa văn Mandala mờ", category: "Hoa văn trang trí", img: "/gallery/mandala.jpg" },
  { title: "Bộ Sticker Typography", category: "Sticker", img: "/gallery/sticker.jpg" },
  // Thêm dữ liệu ở đây
];
---

<section class="bg-surface py-20">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center mb-12">
      <h1 class="text-3xl md:text-5xl font-bold text-copy mb-4">Thư viện mẫu cắt</h1>
      <p class="text-copy-light">Cảm hứng cho không gian và thương hiệu của bạn</p>
    </div>

    <div class="flex flex-wrap justify-center gap-2 mb-10">
      {categories.map(cat => (
        <button class="px-6 py-2 rounded-full bg-white border border-divider text-sm font-medium hover:bg-primary hover:text-white transition-all">
          {cat}
        </button>
      ))}
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4 md:gap-6">
      {galleryItems.map(item => (
        <div class="group bg-white rounded-xl overflow-hidden border border-divider hover:shadow-lg transition-all">
          <div class="aspect-square bg-gray-200 relative overflow-hidden">
            <img src={item.img} alt={item.title} class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
            <div class="absolute inset-0 bg-primary/20 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
              <span class="bg-white text-primary px-4 py-2 rounded-lg font-bold text-sm">Xem chi tiết</span>
            </div>
          </div>
          <div class="p-4">
            <span class="text-[10px] uppercase tracking-widest text-primary font-bold">{item.category}</span>
            <h3 class="text-sm font-bold text-copy mt-1">{item.title}</h3>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
