---
const menuItems = [
  { name: 'Trang chủ', href: '/' },
  { 
    name: 'Dịch vụ', 
    href: '#',
    children: [
      { name: 'Cắt Decal Chữ & Logo', href: '/dich-vu/cat-decal-chu-logo' },
      { name: 'Tem Nhãn & Sticker', href: '/dich-vu/tem-nhan-sticker' },
      { name: 'Decal Phản Quang', href: '/dich-vu/decal-phan-quang' },
      { name: 'Trang trí nội thất', href: '/dich-vu/trang-tri-noi-that' },
      { name: 'Cắt gia công', href: '/dich-vu/cat-decal-gia-cong' },
    ]
  },
  { name: 'Khu vực', href: '/khu-vuc' },
  { name: 'Bảng giá', href: '/bang-gia' },
  { name: 'Liên hệ', href: '/lien-he' },
];
---

<header class="sticky top-0 z-50 bg-primary shadow-md">
  <div class="container mx-auto px-4 py-3 flex items-center justify-between">
    <a href="/" class="flex items-center space-x-2">
      <div class="bg-secondary p-1 rounded">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
        </svg>
      </div>
      <span class="text-xl font-heading font-bold text-white tracking-tight">
        CATDECAL<span class="text-secondary">.VN</span>
      </span>
    </a>

    <nav class="hidden md:block">
      <ul class="flex space-x-8 items-center">
        {menuItems.map((item) => (
          <li class="relative group">
            <a 
              href={item.href} 
              class="text-sm font-medium text-white/90 hover:text-secondary transition-colors flex items-center gap-1 py-2"
            >
              {item.name}
              {item.children && (
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 opacity-50 group-hover:rotate-180 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              )}
            </a>

            {item.children && (
              <ul class="absolute left-0 mt-0 w-56 bg-primary border border-white/10 rounded-lg shadow-xl py-2 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 transform translate-y-2 group-hover:translate-y-0">
                {item.children.map((child) => (
                  <li>
                    <a 
                      href={child.href} 
                      class="block px-4 py-2 text-sm text-white/80 hover:bg-white/5 hover:text-secondary"
                    >
                      {child.name}
                    </a>
                  </li>
                ))}
              </ul>
            )}
          </li>
        ))}
      </ul>
    </nav>

    <div class="flex items-center gap-4">
      <a 
        href="https://zalo.me/your-number" 
        class="hidden sm:inline-flex items-center justify-center bg-secondary text-primary px-5 py-2 rounded-custom font-bold text-sm hover:brightness-110 active:scale-95 transition-all shadow-lg shadow-secondary/20"
      >
        BÁO GIÁ ZALO
      </a>
      
      <button class="md:hidden text-white p-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16m-7 6h7" />
        </svg>
      </button>
    </div>
  </div>
</header>
