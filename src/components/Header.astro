---
const menuData = [
  { name: "Trang chủ", href: "/" },
  { 
    name: "Dịch vụ cắt", 
    href: "/dich-vu",
    submenu: [
      { name: "Cắt Chữ & Logo (Viền)", href: "/dich-vu/cat-chu-logo" },
      { name: "Bế Tem Nhãn (Sticker)", href: "/dich-vu/be-tem-nhan" },
      { name: "Trang Trí Nội Thất", href: "/dich-vu/trang-tri-noi-that" },
      { name: "Cắt Decal Dán Xe", href: "/dich-vu/dan-xe" },
      { name: "Cắt Chuyển Nhiệt (Áo)", href: "/dich-vu/chuyen-nhiet" },
      { name: "Quảng Cáo Khổ Lớn", href: "/dich-vu/quang-cao-kho-lon" }
    ]
  },
  { 
    name: "Vật liệu", 
    href: "/vat-lieu",
    submenu: [
      { name: "Decal Màu (McCal/Avery)", href: "/vat-lieu/decal-mau" },
      { name: "Decal Mờ (Dán kính)", href: "/vat-lieu/decal-mo" },
      { name: "Decal Trong/Sữa", href: "/vat-lieu/decal-trong" },
      { name: "Phản Quang (Biển báo/Xe)", href: "/vat-lieu/decal-phan-quang" },
      { name: "Decal Chuyển Nhiệt PU/PVC", href: "/vat-lieu/decal-chuyen-nhiet" },
      { name: "Interior Film (Gỗ/Đá)", href: "/vat-lieu/interior-film" },
      { name: "Decal Lưới / 7 Màu", href: "/vat-lieu/decal-ky-thuat" },
      { name: "Nam Châm Dẻo", href: "/vat-lieu/nam-cham-deo" }
    ]
  },
  { name: "Blog", href: "/blog" },
  { name: "Báo giá", href: "/bao-gia" },
];
---

<header class="fixed w-full z-[100] transition-all duration-300 bg-primary/95 backdrop-blur-md border-b border-white/5" id="main-header">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-20">
      
      <a href="/" class="flex items-center gap-2">
        <div class="w-10 h-10 bg-secondary rounded-xl flex items-center justify-center rotate-3 shadow-lg shadow-secondary/20">
          <span class="text-primary font-black text-2xl italic">C</span>
        </div>
        <div class="flex flex-col">
          <span class="text-white font-black text-xl leading-none uppercase italic tracking-tighter">CatDecal<span class="text-secondary">.vn</span></span>
          <span class="text-[9px] text-white/40 uppercase tracking-[0.2em] font-bold mt-1 text-nowrap">Gia công chuyên nghiệp</span>
        </div>
      </a>

      <nav class="hidden lg:flex items-center gap-6">
        {menuData.map(item => (
          <div class="group relative py-7">
            <a href={item.href} class="text-[11px] font-black text-white/70 hover:text-secondary uppercase tracking-widest flex items-center gap-1.5">
              {item.name}
              {item.submenu && <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>}
            </a>
            {item.submenu && (
              <div class="absolute top-full left-0 w-72 bg-primary border border-white/10 rounded-2xl py-5 hidden group-hover:block shadow-2xl animate-in fade-in slide-in-from-top-2">
                {item.submenu.map(sub => (
                  <a href={sub.href} class="px-6 py-2.5 text-[10px] font-bold text-white/50 hover:text-secondary hover:bg-white/5 uppercase tracking-wider block">
                    {sub.name}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
        <a href="https://zalo.me/your-number" class="ml-4 bg-secondary text-primary px-6 py-3 rounded-xl font-black text-[11px] uppercase tracking-wider">Zalo Gửi File</a>
      </nav>

      <button class="lg:hidden text-white p-2" id="menu-btn">
        <div class="w-7 h-5 flex flex-col justify-between" id="hamburger">
          <span class="w-full h-1 bg-white rounded-full transition-all"></span>
          <span class="w-full h-1 bg-secondary rounded-full transition-all"></span>
          <span class="w-full h-1 bg-white rounded-full transition-all"></span>
        </div>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="fixed inset-0 bg-primary z-[-1] translate-x-full transition-transform duration-500 lg:hidden overflow-y-auto">
    <div class="pt-24 px-6 pb-20">
      <div class="flex flex-col space-y-2">
        {menuData.map(item => (
          <div class="border-b border-white/5 py-4">
            <a href={item.href} class="text-xl font-black text-white italic uppercase flex justify-between items-center">
              {item.name}
              {item.submenu && <span class="text-secondary text-xs">▼</span>}
            </a>
            
            {item.submenu && (
              <div class="grid grid-cols-1 gap-4 mt-5 ml-4 border-l border-secondary/20 pl-4">
                {item.submenu.map(sub => (
                  <a href={sub.href} class="text-xs font-bold text-white/40 uppercase tracking-widest py-1 active:text-secondary">
                    {sub.name}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
        
        <div class="pt-8">
          <a href="https://zalo.me/your-number" class="bg-secondary text-primary w-full py-5 rounded-2xl font-black text-center uppercase italic block">
            Liên hệ báo giá ngay
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const spans = document.getElementById('hamburger')?.querySelectorAll('span');

  function toggleMenu() {
    const isOpen = mobileMenu?.classList.contains('translate-x-0');
    if (isOpen) {
      mobileMenu?.classList.remove('translate-x-0');
      mobileMenu?.classList.add('translate-x-full');
      document.body.style.overflow = '';
      // Reset Hamburger icon
      spans![0].classList.remove('rotate-45', 'translate-y-[8.5px]');
      spans![1].classList.remove('opacity-0');
      spans![2].classList.remove('-rotate-45', '-translate-y-[8.5px]');
    } else {
      mobileMenu?.classList.remove('translate-x-full');
      mobileMenu?.classList.add('translate-x-0');
      document.body.style.overflow = 'hidden';
      // Transform to X icon
      spans![0].classList.add('rotate-45', 'translate-y-[8.5px]');
      spans![1].classList.add('opacity-0');
      spans![2].classList.add('-rotate-45', '-translate-y-[8.5px]');
    }
  }

  menuBtn?.addEventListener('click', toggleMenu);
</script>
