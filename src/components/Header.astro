---
import { menuData } from '../config/menu';
---

<header class="fixed w-full z-[100] transition-all duration-300 bg-white/90 backdrop-blur-md border-b border-slate-100" id="main-header">
  <div class="container mx-auto px-4">
    <div class="flex items-center justify-between h-16 md:h-20">
      
      <a href="/" class="flex items-center justify-center group">
        <div class="w-10 h-10 bg-secondary rounded-xl flex items-center justify-center shadow-sm transition-transform group-hover:scale-105">
          <span class="text-white font-bold text-2xl italic">C</span>
        </div>
      </a>

      <nav class="hidden lg:flex items-center gap-8">
        {menuData.map(item => (
          <div class="group relative py-7">
            <a href={item.href} class="text-[12px] font-bold text-slate-600 hover:text-secondary uppercase tracking-widest flex items-center gap-1.5 transition-colors">
              {item.name}
              {item.submenu && <svg class="w-3 h-3 opacity-40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19 9l-7 7-7-7" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>}
            </a>
            {item.submenu && (
              <div class="absolute top-full left-0 w-64 bg-white border border-slate-100 rounded-2xl py-4 hidden group-hover:block shadow-xl animate-in fade-in slide-in-from-top-2">
                {item.submenu.map(sub => (
                  <a href={sub.href} class="px-6 py-2 text-[11px] font-semibold text-slate-500 hover:text-secondary hover:bg-slate-50 uppercase tracking-wider block transition-all">
                    {sub.name}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
        <a href="https://zalo.me/your-number" class="ml-4 bg-secondary/10 text-secondary border border-secondary/20 px-5 py-2.5 rounded-xl font-bold text-[11px] uppercase tracking-wider hover:bg-secondary hover:text-white transition-all">
          Zalo Gửi File
        </a>
      </nav>

      <button class="lg:hidden text-slate-800 p-2 z-[110]" id="menu-btn" aria-label="Mở menu">
        <div class="w-6 h-4 flex flex-col justify-between" id="hamburger">
          <span class="w-full h-0.5 bg-slate-800 rounded-full transition-all duration-300"></span>
          <span class="w-full h-0.5 bg-secondary rounded-full transition-all duration-300"></span>
          <span class="w-full h-0.5 bg-slate-800 rounded-full transition-all duration-300"></span>
        </div>
      </button>
    </div>
  </div>

  <div 
    id="mobile-menu" 
    class="fixed inset-0 bg-white z-[105] translate-x-full transition-transform duration-500 lg:hidden flex flex-col h-[100dvh]"
  >
    <div class="flex-1 overflow-y-auto pt-24 pb-12 px-6">
      <div class="flex flex-col space-y-1">
        {menuData.map(item => (
          <div class="border-b border-slate-50 py-4">
            <a href={item.href} class="text-xl font-bold text-slate-800 uppercase flex justify-between items-center active:text-secondary">
              {item.name}
              {item.submenu && <span class="text-secondary text-[10px]">▼</span>}
            </a>
            
            {item.submenu && (
              <div class="grid grid-cols-1 gap-4 mt-5 ml-4 border-l border-slate-100 pl-4">
                {item.submenu.map(sub => (
                  <a href={sub.href} class="text-xs font-bold text-slate-400 uppercase tracking-widest py-1 active:text-secondary transition-colors">
                    {sub.name}
                  </a>
                ))}
              </div>
            )}
          </div>
        ))}
        
        <div class="pt-8">
          <a href="https://zalo.me/your-number" class="bg-secondary/10 text-secondary w-full py-5 rounded-2xl font-bold uppercase tracking-widest block text-center shadow-sm">
            Liên hệ báo giá
          </a>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const spans = document.getElementById('hamburger')?.querySelectorAll('span');

  function toggleMenu() {
    const isOpen = mobileMenu?.classList.contains('translate-x-0');
    if (isOpen) {
      // Đóng menu
      mobileMenu?.classList.remove('translate-x-0');
      mobileMenu?.classList.add('translate-x-full');
      document.body.style.overflow = ''; // Cho phép cuộn trang lại
      if (spans) {
        spans[0].classList.remove('rotate-45', 'translate-y-[7px]');
        spans[1].classList.remove('opacity-0');
        spans[2].classList.remove('-rotate-45', '-translate-y-[7px]');
      }
    } else {
      // Mở menu
      mobileMenu?.classList.remove('translate-x-full');
      mobileMenu?.classList.add('translate-x-0');
      document.body.style.overflow = 'hidden'; // Chặn cuộn trang nền
      if (spans) {
        spans[0].classList.add('rotate-45', 'translate-y-[7px]');
        spans[1].classList.add('opacity-0');
        spans[2].classList.add('-rotate-45', '-translate-y-[7px]');
      }
    }
  }

  menuBtn?.addEventListener('click', toggleMenu);

  // Tự động đóng menu khi click vào một link (đặc biệt quan trọng cho Single Page)
  const navLinks = mobileMenu?.querySelectorAll('a');
  navLinks?.forEach(link => {
    link.addEventListener('click', () => {
      if (mobileMenu?.classList.contains('translate-x-0')) {
        toggleMenu();
      }
    });
  });
</script>
